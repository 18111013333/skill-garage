{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Project Schema",
  "description": "长期项目的数据结构定义，支持跨会话项目管理",
  "type": "object",
  "required": ["project_id", "project_name", "objective", "owner", "status", "created_at"],
  "properties": {
    "project_id": {
      "type": "string",
      "description": "项目唯一标识符，格式：PROJ-YYYY-NNN",
      "pattern": "^PROJ-\\d{4}-\\d{3}$"
    },
    "project_name": {
      "type": "string",
      "description": "项目名称",
      "minLength": 1,
      "maxLength": 200
    },
    "objective": {
      "type": "string",
      "description": "项目核心目标",
      "minLength": 1
    },
    "scope": {
      "type": "object",
      "description": "项目范围定义",
      "properties": {
        "included": {
          "type": "array",
          "items": { "type": "string" },
          "description": "包含范围"
        },
        "excluded": {
          "type": "array",
          "items": { "type": "string" },
          "description": "排除范围"
        },
        "boundaries": {
          "type": "array",
          "items": { "type": "string" },
          "description": "边界条件"
        }
      }
    },
    "owner": {
      "type": "string",
      "description": "项目负责人ID"
    },
    "stakeholders": {
      "type": "array",
      "description": "相关方列表",
      "items": {
        "type": "object",
        "properties": {
          "user_id": { "type": "string" },
          "role": { "type": "string" },
          "involvement": { "type": "string", "enum": ["primary", "secondary", "informed"] }
        }
      }
    },
    "current_phase": {
      "type": "string",
      "description": "当前阶段",
      "enum": ["created", "scoped", "planned", "in_progress", "blocked", "review", "completed", "archived"],
      "default": "created"
    },
    "status": {
      "type": "string",
      "description": "项目状态",
      "enum": ["active", "paused", "completed", "cancelled", "archived"],
      "default": "active"
    },
    "milestones": {
      "type": "array",
      "description": "里程碑列表",
      "items": {
        "type": "object",
        "required": ["milestone_id", "name", "target_date"],
        "properties": {
          "milestone_id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "target_date": { "type": "string", "format": "date-time" },
          "actual_date": { "type": "string", "format": "date-time" },
          "status": { "type": "string", "enum": ["pending", "in_progress", "completed", "skipped"] },
          "deliverables": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "status": { "type": "string" },
                "verification_method": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "dependencies": {
      "type": "object",
      "description": "项目依赖",
      "properties": {
        "task_dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "任务依赖"
        },
        "information_dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "信息依赖"
        },
        "approval_dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "审批依赖"
        },
        "tool_dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "工具依赖"
        },
        "external_dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "外部条件依赖"
        }
      }
    },
    "risks": {
      "type": "array",
      "description": "风险列表",
      "items": {
        "type": "object",
        "properties": {
          "risk_id": { "type": "string" },
          "description": { "type": "string" },
          "probability": { "type": "string", "enum": ["low", "medium", "high"] },
          "impact": { "type": "string", "enum": ["low", "medium", "high"] },
          "mitigation": { "type": "string" },
          "status": { "type": "string", "enum": ["open", "mitigating", "closed"] }
        }
      }
    },
    "success_criteria": {
      "type": "array",
      "description": "成功标准",
      "items": {
        "type": "object",
        "properties": {
          "criterion": { "type": "string" },
          "measurement": { "type": "string" },
          "target": { "type": "string" },
          "verified": { "type": "boolean" }
        }
      }
    },
    "constraints": {
      "type": "object",
      "description": "项目约束",
      "properties": {
        "time_constraints": {
          "type": "object",
          "properties": {
            "deadline": { "type": "string", "format": "date-time" },
            "milestone_deadlines": { "type": "object" }
          }
        },
        "resource_constraints": {
          "type": "object",
          "properties": {
            "budget": { "type": "number" },
            "compute_limit": { "type": "string" },
            "storage_limit": { "type": "string" }
          }
        },
        "quality_constraints": {
          "type": "object",
          "properties": {
            "min_accuracy": { "type": "number" },
            "max_latency": { "type": "string" }
          }
        }
      }
    },
    "memory_scope": {
      "type": "string",
      "description": "项目记忆作用域ID",
      "pattern": "^project_.*$"
    },
    "graph_scope": {
      "type": "string",
      "description": "项目图谱作用域ID"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "创建时间"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time",
      "description": "最后更新时间"
    },
    "updated_by": {
      "type": "string",
      "description": "最后更新者"
    },
    "version": {
      "type": "string",
      "description": "项目版本",
      "default": "1.0"
    },
    "is_session_task": {
      "type": "boolean",
      "description": "是否为会话级任务（非跨会话）",
      "default": false
    },
    "parent_project_id": {
      "type": "string",
      "description": "父项目ID（用于子项目）"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "项目标签"
    }
  }
}
