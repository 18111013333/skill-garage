#!/usr/bin/env python3
"""
小艺 Claw 终极星空鸽子王 - 完整引导模块
V2.8.1 - 2026-04-11

功能：
1. 系统能力全景展示
2. 所有技能介绍
3. 操作方式和快速代码
4. 常用命令速查
5. 拓展思路和功能推荐
6. 每次对话自动引导
"""

import json
from typing import Dict, List, Any, Optional
from pathlib import Path
from datetime import datetime
from dataclasses import dataclass, field
from enum import Enum

from infrastructure.path_resolver import get_project_root

class GuideSection(Enum):
    WELCOME = "welcome"               # 欢迎信息
    CAPABILITIES = "capabilities"     # 能力介绍
    SKILLS = "skills"                 # 技能介绍
    WORKFLOWS = "workflows"           # 工作流
    COMMANDS = "commands"             # 常用命令
    QUICK_CODE = "quick_code"         # 快速代码
    TIPS = "tips"                     # 拓展思路
    RECOMMENDATIONS = "recommendations"  # 功能推荐

@dataclass
class SkillInfo:
    """技能信息"""
    name: str
    display_name: str
    category: str
    description: str
    usage: str
    example: str
    quick_code: str = ""

class CompleteGuide:
    """完整引导模块"""
    
    def __init__(self):
        self.project_root = get_project_root()
        self.guide_path = self.project_root / 'guide'
        
        # 技能清单
        self.skills: Dict[str, SkillInfo] = {}
        
        # 工作流清单
        self.workflows: Dict[str, Dict] = {}
        
        # 常用命令
        self.commands: List[Dict] = []
        
        # 快速代码模板
        self.quick_codes: List[Dict] = []
        
        # 拓展思路
        self.tips: List[str] = []
        
        # 功能推荐
        self.recommendations: List[Dict] = []
        
        self._init_all()
    
    def _init_all(self):
        """初始化所有内容"""
        self._init_skills()
        self._init_workflows()
        self._init_commands()
        self._init_quick_codes()
        self._init_tips()
        self._init_recommendations()
    
