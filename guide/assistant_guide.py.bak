            "💡 **文件处理**: 支持读取和生成多种格式（docx, pdf, xlsx, csv等）",
            "💡 **定时任务**: 可以设置每天、每周、每月的周期性任务",
            "💡 **工作流**: 预设工作流可快速完成复杂任务，如电商选品分析",
            "💡 **技能组合**: 多个技能可以组合使用，如搜索+分析+生成报告",
            "💡 **图片处理**: 发送图片后可以识别、分析、编辑",
            "💡 **数据分析**: 支持Excel、CSV、数据库等多种数据源",
            "💡 **协作功能**: 可以分配任务、发起审批、跟踪进度",
            "💡 **决策支持**: 可以对比方案、预估风险、模拟预演",
            "💡 **自动化**: 在安全边界内可以自动执行任务",
            "💡 **服务包**: 不同服务包有不同能力，可以查看和升级",
            "💡 **成本核算**: 可以查看资源使用和成本消耗",
            "💡 **多端支持**: 支持Web、API、命令行、文件等多种方式调用",
        ]
    
    def _init_recommendations(self):
        """初始化功能推荐"""
        self.recommendations = [
            {
                "scenario": "电商运营",
                "features": ["电商选品分析", "主播/团长筛选", "市场分析报告"],
                "skills": ["xiaoyi-web-search", "data-analysis", "docx"]
            },
            {
                "scenario": "采购寻源",
                "features": ["工厂筛选比价", "供应商评估", "成本分析"],
                "skills": ["xiaoyi-web-search", "excel-analysis", "docx"]
            },
            {
                "scenario": "内容创作",
                "features": ["文章写作", "文案创作", "报告生成"],
                "skills": ["article-writer", "copywriter", "docx"]
            },
            {
                "scenario": "数据分析",
                "features": ["数据清洗", "统计分析", "可视化图表"],
                "skills": ["data-analysis", "excel-analysis", "sqlite"]
            },
            {
                "scenario": "项目管理",
                "features": ["任务分配", "进度跟踪", "审批流程"],
                "skills": ["cron", "docx"]
            },
            {
                "scenario": "代码开发",
                "features": ["代码审计", "Git操作", "TDD开发"],
                "skills": ["code-analysis", "git", "tdd-guide"]
            },
            {
                "scenario": "自动化办公",
                "features": ["定时任务", "自动执行", "批量处理"],
                "skills": ["cron", "playwright", "xiaoyi-gui-agent"]
            },
            {
                "scenario": "市场研究",
                "features": ["市场分析", "竞争调研", "趋势预测"],
                "skills": ["market-research", "xiaoyi-web-search", "data-analysis"]
            }
        ]
    
    # === 输出方法 ===
    
    def get_full_guide(self) -> str:
        """获取完整引导内容"""
        sections = [
            self._get_welcome(),
            self._get_capabilities(),
            self._get_skills_overview(),
            self._get_workflows(),
            self._get_commands(),
            self._get_quick_codes(),
            self._get_tips(),
            self._get_recommendations()
        ]
        return "\n\n".join(sections)
    
    def _get_welcome(self) -> str:
        """欢迎信息"""
        return """👋 欢迎使用 **小艺 Claw 终极星空鸽子王 V2.8.1**！

我是你的智能助手，可以帮助你完成各种任务。

---

## 🎯 快速开始

直接用自然语言描述你的需求：
- "帮我分析电商市场趋势"
- "生成一份销售报告"
- "每天早上9点提醒我"

---

## 💡 试试这些

1. **电商选品分析** - 分析产品趋势，生成选品建议
2. **工厂筛选比价** - 对比供应商，找到最优选择
3. **市场分析报告** - 深度调研，生成专业报告
4. **定时任务** - 设置周期性提醒和自动化
5. **数据分析** - 处理数据，生成图表和洞察"""
    
    def _get_capabilities(self) -> str:
        """能力介绍"""
        return """## 📊 系统能力

| 类别 | 能力 | 说明 |
|------|------|------|
| 🔍 **搜索分析** | 网页搜索、市场分析 | 获取实时信息，深度分析 |
| 📊 **数据处理** | 数据分析、报告生成 | 处理数据，生成洞察 |
| 📝 **文档生成** | Word/PDF/PPT | 创建专业文档 |
| 🖼️ **图片处理** | 识别、编辑、生成 | 图片理解和创作 |
| ⏰ **自动化** | 定时任务、自动执行 | 周期性任务和自动化 |
| 🤝 **协作** | 任务分配、审批流程 | 团队协作管理 |
| 🧠 **记忆** | 信息保存、上下文 | 跨会话记忆 |
| 📈 **决策** | 方案对比、风险预估 | 辅助决策支持 |"""
    
    def _get_skills_overview(self) -> str:
        """技能概览"""
        # 按类别分组
        categories = {}
        for skill in self.skills.values():
            if skill.category not in categories:
                categories[skill.category] = []
            categories[skill.category].append(skill)
        
        lines = ["## 🛠️ 技能分类", ""]
        
        for category, skills in categories.items():
            lines.append(f"### {category}")
            for skill in skills:
                lines.append(f"- **{skill.display_name}**: {skill.description}")
            lines.append("")
        
        return "\n".join(lines)
    
    def _get_workflows(self) -> str:
        """工作流介绍"""
        lines = ["## 🔄 工作流", ""]
        
        for name, wf in self.workflows.items():
            lines.append(f"### {name}")
            lines.append(f"- **说明**: {wf['description']}")
            lines.append(f"- **示例**: `{wf['example']}`")
            lines.append(f"- **输出**: {wf['output']}")
            lines.append("")
        
        return "\n".join(lines)
    
    def _get_commands(self) -> str:
        """常用命令"""
        lines = ["## 📋 常用命令", ""]
        
        # 按类别分组
        categories = {}
        for cmd in self.commands:
            cat = cmd['category']
            if cat not in categories:
                categories[cat] = []
            categories[cat].append(cmd)
        
        for cat, cmds in categories.items():
            lines.append(f"### {cat}")
            for cmd in cmds:
                lines.append(f"- `{cmd['command']}`: {cmd['description']}")
            lines.append("")
        
        return "\n".join(lines)
    
    def _get_quick_codes(self) -> str:
        """快速代码"""
        lines = ["## 💻 快速代码模板", ""]
        
        for code in self.quick_codes:
            lines.append(f"### {code['name']}")
            lines.append(f"```python\n{code['code']}\n```")
            lines.append("")
        
        return "\n".join(lines)
    
    def _get_tips(self) -> str:
        """拓展思路"""
        lines = ["## 💡 使用技巧", ""]
        for tip in self.tips:
            lines.append(f"- {tip}")
        return "\n".join(lines)
    
    def _get_recommendations(self) -> str:
        """功能推荐"""
        lines = ["## 🎯 场景推荐", ""]
        
        for rec in self.recommendations:
            lines.append(f"### {rec['scenario']}")
            lines.append(f"- **推荐功能**: {', '.join(rec['features'])}")
            lines.append(f"- **相关技能**: {', '.join(rec['skills'])}")
            lines.append("")
        
        return "\n".join(lines)
    
    # === 快速查询方法 ===
    
    def get_skill_detail(self, skill_name: str) -> Optional[str]:
        """获取技能详情"""
        skill = self.skills.get(skill_name)
        if not skill:
            return None
        
        return f"""## {skill.display_name}

- **类别**: {skill.category}
- **说明**: {skill.description}
- **用法**: {skill.usage}
- **示例**: `{skill.example}`
{f'- **快速代码**:\\n```python\\n{skill.quick_code}\\n```' if skill.quick_code else ''}"""
    
    def get_workflow_detail(self, workflow_name: str) -> Optional[str]:
        """获取工作流详情"""
        wf = self.workflows.get(workflow_name)
        if not wf:
            return None
        
        lines = [
            f"## {workflow_name}",
            "",
            f"**说明**: {wf['description']}",
            "",
            "### 执行步骤",
            ""
        ]
        for step in wf['steps']:
            lines.append(f"- {step}")
        
        lines.extend([
            "",
            "### 使用示例",
            f"`{wf['example']}`",
            "",
            f"**输出**: {wf['output']}"
        ])
        
        return "\n".join(lines)
    
    def search_skills(self, keyword: str) -> List[SkillInfo]:
        """搜索技能"""
        results = []
        keyword_lower = keyword.lower()
        
        for skill in self.skills.values():
            if (keyword_lower in skill.name.lower() or
                keyword_lower in skill.display_name.lower() or
                keyword_lower in skill.description.lower() or
                keyword_lower in skill.category.lower()):
                results.append(skill)
        
        return results
    
    def get_quick_reference(self) -> str:
        """快速参考卡"""
        return """## 📋 快速参考

### 常用命令
| 命令 | 说明 |
|------|------|
| `帮助` | 查看能力列表 |
| `搜索 xxx` | 网页搜索 |
| `生成 xxx 报告` | 创建文档 |
| `分析数据` | 数据分析 |
| `每天 xxx 提醒我` | 定时任务 |
| `记住 xxx` | 保存记忆 |

### 工作流
| 工作流 | 用途 |
|--------|------|
| 电商选品分析 | 分析产品趋势 |
| 工厂筛选比价 | 供应商对比 |
| 主播/团长筛选 | 合作伙伴筛选 |
| 店铺启动 | 新店开业指导 |
| 代码审计 | 代码质量检查 |
| 市场分析报告 | 市场调研 |

### 技能分类
| 类别 | 技能示例 |
|------|----------|
| 文档处理 | docx, pdf, pptx |
| 数据分析 | data-analysis, excel-analysis |
| 网络服务 | xiaoyi-web-search, web-browsing |
| 图片处理 | image-cog, xiaoyi-image-understanding |
| 自动化 | cron, xiaoyi-gui-agent |

---

💡 **提示**: 直接用自然语言描述需求，我会自动匹配合适的能力！"""

# 全局实例
_complete_guide = None


