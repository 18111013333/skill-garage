{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Resource Schema",
  "description": "资源对象结构定义",
  "type": "object",
  "required": ["resource_id", "resource_type", "capacity", "status", "created_at"],
  "properties": {
    "resource_id": {
      "type": "string",
      "description": "资源唯一标识符",
      "pattern": "^RES-[a-z]+-\\d{4}$"
    },
    "resource_name": {
      "type": "string",
      "description": "资源名称"
    },
    "resource_type": {
      "type": "string",
      "description": "资源类型",
      "enum": [
        "model_compute",
        "tool_quota",
        "approval_quota",
        "document_window",
        "external_api_quota",
        "human_confirmation_slot",
        "storage",
        "network_bandwidth",
        "memory",
        "concurrent_task"
      ]
    },
    "description": {
      "type": "string",
      "description": "资源描述"
    },
    "owner": {
      "type": "string",
      "description": "资源所有者"
    },
    "capacity": {
      "type": "object",
      "description": "资源容量",
      "properties": {
        "total": {
          "type": "number",
          "description": "总容量"
        },
        "unit": {
          "type": "string",
          "description": "容量单位",
          "enum": ["tokens", "calls", "slots", "MB", "GB", "concurrent", "percentage"]
        },
        "reserved": {
          "type": "number",
          "description": "预留容量"
        },
        "available": {
          "type": "number",
          "description": "可用容量"
        }
      }
    },
    "availability": {
      "type": "object",
      "description": "可用性配置",
      "properties": {
        "schedule": {
          "type": "object",
          "properties": {
            "timezone": { "type": "string" },
            "available_hours": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "day": { "type": "string" },
                  "start": { "type": "string" },
                  "end": { "type": "string" }
                }
              }
            }
          }
        },
        "maintenance_windows": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "start": { "type": "string", "format": "date-time" },
              "end": { "type": "string", "format": "date-time" },
              "reason": { "type": "string" }
            }
          }
        }
      }
    },
    "cost": {
      "type": "object",
      "description": "成本信息",
      "properties": {
        "unit_cost": { "type": "number" },
        "currency": { "type": "string", "default": "CNY" },
        "billing_cycle": { "type": "string", "enum": ["per_use", "hourly", "daily", "monthly"] },
        "budget_limit": { "type": "number" },
        "current_spend": { "type": "number" }
      }
    },
    "risk_level": {
      "type": "string",
      "description": "资源风险等级",
      "enum": ["low", "medium", "high", "critical"],
      "default": "low"
    },
    "project_bindings": {
      "type": "array",
      "description": "项目绑定",
      "items": {
        "type": "object",
        "properties": {
          "project_id": { "type": "string" },
          "allocation_type": { "type": "string", "enum": ["fixed", "flexible", "shared", "reserved"] },
          "allocation_amount": { "type": "number" },
          "priority": { "type": "integer" },
          "bound_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "environment_scope": {
      "type": "string",
      "description": "环境作用域",
      "enum": ["global", "production", "staging", "development", "project_specific"]
    },
    "expiration": {
      "type": "object",
      "description": "过期配置",
      "properties": {
        "expires_at": { "type": "string", "format": "date-time" },
        "renewal_policy": { "type": "string", "enum": ["auto", "manual", "none"] },
        "expiry_action": { "type": "string", "enum": ["deallocate", "archive", "notify"] }
      }
    },
    "quotas": {
      "type": "object",
      "description": "配额限制",
      "properties": {
        "rate_limit": {
          "type": "object",
          "properties": {
            "requests_per_second": { "type": "number" },
            "requests_per_minute": { "type": "number" },
            "requests_per_hour": { "type": "number" }
          }
        },
        "daily_limit": { "type": "number" },
        "monthly_limit": { "type": "number" },
        "burst_limit": { "type": "number" }
      }
    },
    "monitoring": {
      "type": "object",
      "description": "监控配置",
      "properties": {
        "health_check_interval": { "type": "string" },
        "alert_thresholds": {
          "type": "object",
          "properties": {
            "usage_percent": { "type": "number" },
            "error_rate": { "type": "number" },
            "latency_ms": { "type": "number" }
          }
        }
      }
    },
    "status": {
      "type": "string",
      "description": "资源状态",
      "enum": ["available", "in_use", "depleted", "maintenance", "offline", "reserved"],
      "default": "available"
    },
    "current_usage": {
      "type": "object",
      "description": "当前使用情况",
      "properties": {
        "used": { "type": "number" },
        "usage_percent": { "type": "number" },
        "active_allocations": { "type": "integer" },
        "last_used_at": { "type": "string", "format": "date-time" }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
