{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Service Catalog",
  "description": "平台正式服务目录 - 终极鸽子王 V27.0",
  "version": "1.0.0",
  "type": "object",
  "required": ["service_id", "service_name", "service_owner", "service_tier", "status"],
  "properties": {
    "service_id": {
      "type": "string",
      "description": "服务唯一标识符",
      "pattern": "^svc_[a-zA-Z0-9_]+$"
    },
    "service_name": {
      "type": "string",
      "description": "服务名称",
      "minLength": 1,
      "maxLength": 128
    },
    "service_code": {
      "type": "string",
      "description": "服务代码（用于API、配置等）",
      "pattern": "^[a-z_]{3,64}$"
    },
    "service_description": {
      "type": "string",
      "description": "服务描述",
      "maxLength": 1024
    },
    "service_owner": {
      "type": "object",
      "properties": {
        "primary_owner": {
          "type": "object",
          "properties": {
            "user_id": { "type": "string" },
            "name": { "type": "string" },
            "team": { "type": "string" },
            "contact": { "type": "string" }
          }
        },
        "backup_owner": {
          "type": "object",
          "properties": {
            "user_id": { "type": "string" },
            "name": { "type": "string" },
            "team": { "type": "string" }
          }
        },
        "operations_owner": {
          "type": "object",
          "properties": {
            "user_id": { "type": "string" },
            "name": { "type": "string" },
            "team": { "type": "string" }
          }
        },
        "incident_owner": {
          "type": "object",
          "properties": {
            "user_id": { "type": "string" },
            "name": { "type": "string" },
            "team": { "type": "string" }
          }
        },
        "change_owner": {
          "type": "object",
          "properties": {
            "user_id": { "type": "string" },
            "name": { "type": "string" },
            "team": { "type": "string" }
          }
        }
      },
      "description": "服务归属信息"
    },
    "service_tier": {
      "type": "string",
      "enum": ["tier0", "tier1", "tier2", "tier3", "experimental"],
      "description": "服务等级"
    },
    "service_category": {
      "type": "string",
      "enum": [
        "core_platform",
        "data_service",
        "ai_service",
        "integration_service",
        "governance_service",
        "security_service",
        "analytics_service",
        "developer_service",
        "business_service",
        "infrastructure_service"
      ],
      "description": "服务类别"
    },
    "dependent_modules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "module_id": { "type": "string" },
          "module_name": { "type": "string" },
          "dependency_type": {
            "type": "string",
            "enum": ["required", "optional", "fallback"]
          },
          "criticality": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          }
        }
      },
      "description": "依赖的模块列表"
    },
    "dependent_connectors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "connector_id": { "type": "string" },
          "connector_name": { "type": "string" },
          "dependency_type": {
            "type": "string",
            "enum": ["required", "optional", "fallback"]
          },
          "criticality": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          }
        }
      },
      "description": "依赖的连接器列表"
    },
    "dependent_services": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "service_id": { "type": "string" },
          "service_name": { "type": "string" },
          "dependency_type": {
            "type": "string",
            "enum": ["required", "optional", "fallback"]
          }
        }
      },
      "description": "依赖的其他服务"
    },
    "exposed_interfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "interface_id": { "type": "string" },
          "interface_name": { "type": "string" },
          "interface_type": {
            "type": "string",
            "enum": ["api", "sdk", "cli", "webhook", "event", "grpc", "graphql"]
          },
          "visibility": {
            "type": "string",
            "enum": ["public", "internal", "partner", "tenant"]
          },
          "version": { "type": "string" },
          "deprecation_status": {
            "type": "string",
            "enum": ["active", "deprecated", "sunset"]
          }
        }
      },
      "description": "暴露的接口列表"
    },
    "criticality": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"],
      "description": "服务关键性"
    },
    "sla": {
      "type": "object",
      "properties": {
        "availability_target": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "可用性目标（%）"
        },
        "response_time_target": {
          "type": "number",
          "description": "响应时间目标（ms）"
        },
        "error_rate_target": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "错误率目标（%）"
        },
        "support_response_time": {
          "type": "object",
          "properties": {
            "sev0": { "type": "string" },
            "sev1": { "type": "string" },
            "sev2": { "type": "string" },
            "sev3": { "type": "string" }
          }
        }
      },
      "description": "SLA 配置"
    },
    "supported_regions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "支持的区域列表"
    },
    "supported_environments": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["development", "staging", "production", "sandbox", "dr"]
      },
      "description": "支持的环境列表"
    },
    "data_classification": {
      "type": "string",
      "enum": ["public", "internal", "confidential", "restricted"],
      "description": "数据分类"
    },
    "compliance_requirements": {
      "type": "array",
      "items": { "type": "string" },
      "description": "合规要求列表"
    },
    "cost_center": {
      "type": "string",
      "description": "成本中心"
    },
    "billing_model": {
      "type": "string",
      "enum": ["subscription", "usage_based", "hybrid", "free", "partner_resell"],
      "description": "计费模式"
    },
    "documentation": {
      "type": "object",
      "properties": {
        "api_docs": { "type": "string" },
        "user_guide": { "type": "string" },
        "runbook": { "type": "string" },
        "architecture": { "type": "string" }
      },
      "description": "文档链接"
    },
    "monitoring": {
      "type": "object",
      "properties": {
        "dashboard_url": { "type": "string" },
        "alert_channel": { "type": "string" },
        "oncall_rotation": { "type": "string" }
      },
      "description": "监控配置"
    },
    "status": {
      "type": "string",
      "enum": ["active", "deprecated", "maintenance", "development", "planned", "retired"],
      "description": "服务状态"
    },
    "lifecycle": {
      "type": "object",
      "properties": {
        "created_at": { "type": "string", "format": "date-time" },
        "launched_at": { "type": "string", "format": "date-time" },
        "deprecated_at": { "type": "string", "format": "date-time" },
        "retired_at": { "type": "string", "format": "date-time" },
        "last_review": { "type": "string", "format": "date-time" },
        "next_review": { "type": "string", "format": "date-time" }
      },
      "description": "生命周期信息"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "扩展元数据"
    }
  },
  "service_tiers": {
    "tier0": {
      "name": "核心服务",
      "description": "平台核心能力，不可用则平台不可用",
      "sla_target": "99.99%",
      "support_level": "24/7",
      "change_freeze": "严格限制",
      "examples": ["记忆服务", "执行服务", "会话服务"]
    },
    "tier1": {
      "name": "关键服务",
      "description": "关键业务能力，不可用则核心功能受损",
      "sla_target": "99.9%",
      "support_level": "24/7",
      "change_freeze": "限制",
      "examples": ["搜索服务", "知识服务", "技能服务"]
    },
    "tier2": {
      "name": "标准服务",
      "description": "标准业务能力，不可用则部分功能受损",
      "sla_target": "99.5%",
      "support_level": "工作时间+值班",
      "change_freeze": "正常",
      "examples": ["报表服务", "分析服务", "集成服务"]
    },
    "tier3": {
      "name": "辅助服务",
      "description": "辅助能力，不可用影响有限",
      "sla_target": "99%",
      "support_level": "工作时间",
      "change_freeze": "宽松",
      "examples": ["文档服务", "通知服务", "日志服务"]
    },
    "experimental": {
      "name": "实验服务",
      "description": "实验性能力，可能变更或废弃",
      "sla_target": "best effort",
      "support_level": "有限支持",
      "change_freeze": "无限制",
      "examples": ["新功能预览", "测试服务"]
    }
  },
  "service_categories": {
    "core_platform": { "description": "核心平台服务" },
    "data_service": { "description": "数据服务" },
    "ai_service": { "description": "AI 服务" },
    "integration_service": { "description": "集成服务" },
    "governance_service": { "description": "治理服务" },
    "security_service": { "description": "安全服务" },
    "analytics_service": { "description": "分析服务" },
    "developer_service": { "description": "开发者服务" },
    "business_service": { "description": "业务服务" },
    "infrastructure_service": { "description": "基础设施服务" }
  }
}
