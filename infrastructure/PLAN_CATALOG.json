  "support_levels": {
    "community": {
      "name": "社区支持",
      "channels": ["forum", "documentation"],
      "response_time": "best_effort"
    },
    "standard": {
      "name": "标准支持",
      "channels": ["email", "forum"],
      "response_time": "24_hours"
    },
    "priority": {
      "name": "优先支持",
      "channels": ["email", "chat"],
      "response_time": "4_hours"
    },
    "dedicated": {
      "name": "专属支持",
      "channels": ["email", "chat", "phone"],
      "response_time": "2_hours",
      "dedicated_manager": true
    },
    "dedicated_24_7": {
      "name": "7x24 专属支持",
      "channels": ["email", "chat", "phone"],
      "response_time": "1_hour",
      "dedicated_manager": true,
      "24_7_coverage": true
    }
  },
  
  "compliance_modes": {
    "standard": {
      "name": "标准合规",
      "review_frequency": "on_demand",
      "audit_retention": "3_years"
    },
    "enhanced": {
      "name": "增强合规",
      "review_frequency": "quarterly",
      "audit_retention": "5_years",
      "additional_controls": true
    },
    "strict": {
      "name": "严格合规",
      "review_frequency": "monthly",
      "audit_retention": "7_years",
      "additional_controls": true,
      "external_audit": true
    }
