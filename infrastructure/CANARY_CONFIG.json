{
  "version": "1.0.0",
  "lastUpdated": "2026-04-06T11:12:00+08:00",
  "description": "灰度发布配置",
  "stages": [
    {
      "name": "Canary",
      "traffic": 5,
      "duration": 3600,
      "passCriteria": {
        "errorRate": 1,
        "latencyMultiplier": 1.5
      }
    },
    {
      "name": "Early",
      "traffic": 20,
      "duration": 7200,
      "passCriteria": {
        "errorRate": 2,
        "latencyMultiplier": 1.5
      }
    },
    {
      "name": "Mid",
      "traffic": 50,
      "duration": 14400,
      "passCriteria": {
        "errorRate": 3,
        "latencyMultiplier": 2
      }
    },
    {
      "name": "Full",
      "traffic": 100,
      "duration": 0,
      "passCriteria": {}
    }
  ],
  "types": {
    "config_change": {
      "strategy": ["Canary", "Full"],
      "rollbackTime": 300,
      "autoApprove": true
    },
    "skill_update": {
      "strategy": ["Canary", "Full"],
      "rollbackTime": 600,
      "autoApprove": true
    },
    "skill_add": {
      "strategy": ["Canary", "Full"],
      "rollbackTime": 900,
      "autoApprove": true
    },
    "skill_remove": {
      "strategy": ["Canary", "Full"],
      "rollbackTime": 300,
      "autoApprove": true
    },
    "minor_upgrade": {
      "strategy": ["Canary", "Full"],
      "rollbackTime": 900,
      "autoApprove": true
    },
    "major_upgrade": {
      "strategy": ["Canary", "Early", "Mid", "Full"],
      "rollbackTime": 1800,
      "autoApprove": false
    },
    "architecture_change": {
      "strategy": ["Canary", "Early", "Mid", "Full"],
      "rollbackTime": 3600,
      "autoApprove": false
    }
  },
  "checks": {
    "preRelease": [
      {
        "name": "unit_tests",
        "command": "npm test",
        "required": true
      },
      {
        "name": "integration_tests",
        "command": "npm run test:integration",
        "required": true
      },
      {
        "name": "regression_tests",
        "command": "npm run test:regression",
        "required": true
      },
      {
        "name": "config_validation",
        "command": "openclaw validate-config",
        "required": true
      }
    ],
    "duringRelease": [
      {
        "name": "error_rate",
        "metric": "errors_total / requests_total",
        "threshold": 5,
        "action": "alert"
      },
      {
        "name": "latency",
        "metric": "execution_duration_ms_p95",
        "threshold": "baseline * 2",
        "action": "alert"
      },
      {
        "name": "resource_usage",
        "metric": "system_memory_usage",
        "threshold": 90,
        "action": "alert"
      }
    ],
    "postRelease": [
      {
        "name": "functionality",
        "check": "core_features_pass",
        "required": true
      },
      {
        "name": "performance",
        "check": "performance_not_degraded",
        "required": true
      },
      {
        "name": "no_new_errors",
        "check": "no_new_error_types",
        "required": true
      }
    ]
  },
  "rollback": {
    "auto": [
      {
        "condition": "error_rate > 10",
        "action": "full_rollback"
      },
      {
        "condition": "error_rate > 5",
        "action": "stage_rollback"
      },
      {
        "condition": "critical_error",
        "action": "full_rollback"
      },
      {
        "condition": "security_issue",
        "action": "full_rollback"
      }
    ],
    "manual": {
      "enabled": true,
      "reasons": ["user_complaint", "performance_issue", "functionality_issue"]
    },
    "timeLimit": {
      "config_change": 300,
      "skill_change": 600,
      "system_upgrade": 1800
    }
  },
  "approval": {
    "auto": {
      "types": ["config_change", "skill_update", "skill_add", "skill_remove", "minor_upgrade"],
      "conditions": ["tests_pass", "config_valid"]
    },
    "manual": {
      "types": ["major_upgrade", "architecture_change"],
      "approvers": ["admin"],
      "timeout": 3600
    }
  },
  "monitoring": {
    "metrics": [
      "error_rate",
      "latency_p50",
      "latency_p95",
      "latency_p99",
      "throughput",
      "resource_usage"
    ],
    "alertChannels": ["message", "log"],
    "dashboard": "canary/dashboard"
  }
}
