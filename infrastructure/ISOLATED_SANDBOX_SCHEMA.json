{
  "schema": "isolated_sandbox",
  "version": "1.0.0",
  "description": "客户隔离预演环境结构定义",
  "sandbox_types": [
    {
      "sandbox_id": "SB-DEV",
      "type": "development",
      "purpose": "开发测试",
      "region": "auto",
      "data_mode": "synthetic",
      "connector_mode": "mock",
      "allowed_actions": [
        "all"
      ],
      "retention_period": 30,
      "teardown_policy": "auto"
    },
    {
      "sandbox_id": "SB-UAT",
      "type": "uat",
      "purpose": "用户验收测试",
      "region": "customer_region",
      "data_mode": "anonymized",
      "connector_mode": "test",
      "allowed_actions": [
        "standard"
      ],
      "retention_period": 60,
      "teardown_policy": "manual"
    },
    {
      "sandbox_id": "SB-STAGING",
      "type": "staging",
      "purpose": "上线前预演",
      "region": "customer_region",
      "data_mode": "production_copy",
      "connector_mode": "production_mirror",
      "allowed_actions": [
        "restricted"
      ],
      "retention_period": 14,
      "teardown_policy": "manual"
    }
  ],
  "data_modes": {
    "synthetic": {
      "description": "合成数据",
      "data_source": "generated",
      "privacy_level": "none"
    },
    "anonymized": {
      "description": "脱敏数据",
      "data_source": "production_anonymized",
      "privacy_level": "high"
    },
    "production_copy": {
      "description": "生产数据副本",
      "data_source": "production_copy",
      "privacy_level": "critical"
    }
  },
  "connector_modes": {
    "mock": {
      "description": "模拟连接器",
      "real_calls": false,
      "data_simulation": true
    },
    "test": {
      "description": "测试连接器",
      "real_calls": true,
      "test_endpoints": true
    },
    "production_mirror": {
      "description": "生产镜像连接器",
      "real_calls": true,
      "production_endpoints": true,
      "read_only": true
    }
  }
}