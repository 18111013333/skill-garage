{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tenant Schema",
  "description": "租户对象正式建模 - 终极鸽子王 V27.0",
  "version": "1.0.0",
  "type": "object",
  "required": ["tenant_id", "tenant_name", "tenant_type", "status", "created_at"],
  "properties": {
    "tenant_id": {
      "type": "string",
      "description": "租户唯一标识符",
      "pattern": "^tenant_[a-zA-Z0-9]{16}$"
    },
    "tenant_name": {
      "type": "string",
      "description": "租户名称",
      "minLength": 1,
      "maxLength": 256
    },
    "tenant_code": {
      "type": "string",
      "description": "租户代码（用于URL、标识等）",
      "pattern": "^[a-z0-9_]{3,32}$"
    },
    "tenant_type": {
      "type": "string",
      "enum": ["individual", "team", "organization", "enterprise", "partner", "trial"],
      "description": "租户类型"
    },
    "parent_tenant_id": {
      "type": "string",
      "description": "父租户ID（用于多级租户结构）",
      "pattern": "^tenant_[a-zA-Z0-9]{16}$"
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["user_id"],
        "properties": {
          "user_id": { "type": "string" },
          "role": {
            "type": "string",
            "enum": ["primary_owner", "co_owner", "admin"]
          },
          "assigned_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "minItems": 1,
      "description": "租户所有者列表"
    },
    "org_units": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["org_unit_id", "org_unit_name"],
        "properties": {
          "org_unit_id": { "type": "string" },
          "org_unit_name": { "type": "string" },
          "parent_org_unit_id": { "type": "string" },
          "managers": {
            "type": "array",
            "items": { "type": "string" }
          },
          "members": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "description": "组织单元结构"
    },
    "policy_bundle": {
      "type": "object",
      "properties": {
        "security_policy_id": { "type": "string" },
        "privacy_policy_id": { "type": "string" },
        "retention_policy_id": { "type": "string" },
        "compliance_policy_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "custom_policies": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "policy_id": { "type": "string" },
              "policy_name": { "type": "string" },
              "policy_type": { "type": "string" }
            }
          }
        }
      },
      "description": "策略包配置"
    },
    "data_boundary": {
      "type": "object",
      "properties": {
        "storage_region": {
          "type": "string",
          "description": "数据存储区域"
        },
        "allowed_regions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "允许的数据处理区域"
        },
        "cross_region_transfer_allowed": {
          "type": "boolean",
          "description": "是否允许跨区域传输"
        },
        "encryption_at_rest": {
          "type": "boolean",
          "description": "静态加密"
        },
        "encryption_in_transit": {
          "type": "boolean",
          "description": "传输加密"
        },
        "customer_managed_keys": {
          "type": "boolean",
          "description": "客户管理密钥"
        },
        "data_residency_requirements": {
          "type": "array",
          "items": { "type": "string" },
          "description": "数据驻留要求"
        }
      },
      "description": "数据边界配置"
    },
    "feature_scope": {
      "type": "object",
      "properties": {
        "tier": {
          "type": "string",
          "enum": ["free", "basic", "professional", "enterprise", "custom"],
          "description": "功能层级"
        },
        "enabled_features": {
          "type": "array",
          "items": { "type": "string" },
          "description": "已启用功能列表"
        },
        "disabled_features": {
          "type": "array",
          "items": { "type": "string" },
          "description": "已禁用功能列表"
        },
        "feature_limits": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "limit": { "type": "number" },
              "current_usage": { "type": "number" },
              "reset_cycle": { "type": "string" }
            }
          },
          "description": "功能限制配置"
        },
        "custom_features": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "feature_id": { "type": "string" },
              "feature_name": { "type": "string" },
              "enabled": { "type": "boolean" }
            }
          },
          "description": "自定义功能配置"
        }
      },
      "description": "功能范围配置"
    },
    "environments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["env_id", "env_type"],
        "properties": {
          "env_id": { "type": "string" },
          "env_name": { "type": "string" },
          "env_type": {
            "type": "string",
            "enum": ["development", "staging", "production", "sandbox", "dr"]
          },
          "is_default": { "type": "boolean" },
          "data_isolation": { "type": "boolean" },
          "config_override": { "type": "object" }
        }
      },
      "description": "环境配置"
    },
    "branding": {
      "type": "object",
      "properties": {
        "logo_url": { "type": "string" },
        "primary_color": { "type": "string" },
        "secondary_color": { "type": "string" },
        "custom_domain": { "type": "string" },
        "custom_css": { "type": "string" },
        "email_templates": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "description": "品牌配置"
    },
    "integrations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "integration_id": { "type": "string" },
          "integration_type": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["active", "inactive", "error", "pending"]
          },
          "config": { "type": "object" }
        }
      },
      "description": "集成配置"
    },
    "billing": {
      "type": "object",
      "properties": {
        "billing_model": {
          "type": "string",
          "enum": ["subscription", "usage_based", "hybrid", "partner_resell"]
        },
        "billing_cycle": {
          "type": "string",
          "enum": ["monthly", "quarterly", "annual"]
        },
        "currency": { "type": "string" },
        "payment_method": { "type": "string" },
        "billing_contact": { "type": "object" }
      },
      "description": "计费配置"
    },
    "status": {
      "type": "string",
      "enum": ["active", "suspended", "pending", "trial", "migrating", "terminated"],
      "description": "租户状态"
    },
    "trial_info": {
      "type": "object",
      "properties": {
        "trial_start": { "type": "string", "format": "date-time" },
        "trial_end": { "type": "string", "format": "date-time" },
        "trial_features": { "type": "array", "items": { "type": "string" } },
        "converted": { "type": "boolean" }
      },
      "description": "试用信息"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "创建时间"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "更新时间"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "扩展元数据"
    }
  },
  "tenant_types": {
    "individual": {
      "description": "个人租户",
      "max_users": 1,
      "default_tier": "free"
    },
    "team": {
      "description": "团队租户",
      "max_users": 50,
      "default_tier": "basic"
    },
    "organization": {
      "description": "组织租户",
      "max_users": 500,
      "default_tier": "professional",
      "supports_org_units": true
    },
    "enterprise": {
      "description": "企业租户",
      "max_users": "unlimited",
      "default_tier": "enterprise",
      "supports_org_units": true,
      "supports_multi_region": true
    },
    "partner": {
      "description": "合作伙伴租户",
      "supports_resell": true,
      "supports_white_label": true
    },
    "trial": {
      "description": "试用租户",
      "trial_duration_days": 30,
      "auto_convert": false
    }
  },
  "isolation_rules": {
    "data_isolation": "strict",
    "memory_isolation": "strict",
    "config_isolation": "strict",
    "log_isolation": "strict",
    "cache_isolation": "strict",
    "event_isolation": "strict",
    "cross_tenant_access": "denied_by_default"
  }
}
