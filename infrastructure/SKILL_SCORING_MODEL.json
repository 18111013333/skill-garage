{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill Scoring Model",
  "description": "技能评分模型 - 终极鸽子王 V27.0",
  "version": "1.0.0",
  "type": "object",
  "required": ["skill_id", "usage_frequency", "success_rate", "business_value", "maintenance_cost", "risk_level"],
  "properties": {
    "skill_id": {
      "type": "string",
      "description": "技能唯一标识符",
      "pattern": "^skill_[a-zA-Z0-9_]+$"
    },
    "skill_name": {
      "type": "string",
      "description": "技能名称"
    },
    "skill_category": {
      "type": "string",
      "enum": ["core", "high_freq", "standard", "experimental", "low_value", "deprecate"],
      "description": "技能分类"
    },
    "usage_frequency": {
      "type": "object",
      "properties": {
        "daily_calls": {
          "type": "number",
          "minimum": 0,
          "description": "日均调用量"
        },
        "weekly_calls": {
          "type": "number",
          "minimum": 0,
          "description": "周均调用量"
        },
        "monthly_calls": {
          "type": "number",
          "minimum": 0,
          "description": "月均调用量"
        },
        "trend": {
          "type": "string",
          "enum": ["increasing", "stable", "decreasing"],
          "description": "使用趋势"
        },
        "trend_rate": {
          "type": "number",
          "description": "趋势变化率（%）"
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "使用频率得分"
        }
      },
      "description": "使用频率指标"
    },
    "success_rate": {
      "type": "object",
      "properties": {
        "total_executions": {
          "type": "number",
          "minimum": 0,
          "description": "总执行次数"
        },
        "successful_executions": {
          "type": "number",
          "minimum": 0,
          "description": "成功执行次数"
        },
        "failed_executions": {
          "type": "number",
          "minimum": 0,
          "description": "失败执行次数"
        },
        "success_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "成功率（0-1）"
        },
        "error_types": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "error_type": { "type": "string" },
              "count": { "type": "number" },
              "percentage": { "type": "number" }
            }
          },
          "description": "错误类型分布"
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "成功率得分"
        }
      },
      "description": "成功率指标"
    },
    "business_value": {
      "type": "object",
      "properties": {
        "user_coverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "用户覆盖率（使用该技能的用户比例）"
        },
        "revenue_impact": {
          "type": "string",
          "enum": ["high", "medium", "low", "none"],
          "description": "收入影响"
        },
        "strategic_importance": {
          "type": "string",
          "enum": ["critical", "important", "normal", "low"],
          "description": "战略重要性"
        },
        "customer_satisfaction": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "客户满意度评分"
        },
        "dependency_count": {
          "type": "number",
          "minimum": 0,
          "description": "依赖此技能的其他技能数"
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "业务价值得分"
        }
      },
      "description": "业务价值指标"
    },
    "maintenance_cost": {
      "type": "object",
      "properties": {
        "complexity": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "description": "复杂度"
        },
        "code_lines": {
          "type": "number",
          "minimum": 0,
          "description": "代码行数"
        },
        "dependencies": {
          "type": "number",
          "minimum": 0,
          "description": "外部依赖数"
        },
        "bug_count": {
          "type": "number",
          "minimum": 0,
          "description": "已知Bug数"
        },
        "last_update": {
          "type": "string",
          "format": "date-time",
          "description": "最后更新时间"
        },
        "update_frequency": {
          "type": "string",
          "enum": ["frequent", "normal", "rare", "never"],
          "description": "更新频率"
        },
        "support_tickets": {
          "type": "number",
          "minimum": 0,
          "description": "支持工单数（月）"
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "维护成本得分（越高成本越低）"
        }
      },
      "description": "维护成本指标"
    },
    "risk_level": {
      "type": "object",
      "properties": {
        "security_risk": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "none"],
          "description": "安全风险"
        },
        "stability_risk": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "none"],
          "description": "稳定性风险"
        },
        "dependency_risk": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "none"],
          "description": "依赖风险"
        },
        "deprecation_risk": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "none"],
          "description": "废弃风险"
        },
        "vulnerabilities": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "vuln_id": { "type": "string" },
              "severity": { "type": "string" },
              "status": { "type": "string" }
            }
          },
          "description": "已知漏洞"
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "风险得分（越高风险越低）"
        }
      },
      "description": "风险等级指标"
    },
    "composite_score": {
      "type": "object",
      "properties": {
        "total_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "综合得分"
        },
        "weighted_components": {
          "type": "object",
          "properties": {
            "usage_frequency": {
              "type": "number",
              "description": "使用频率加权得分"
            },
            "success_rate": {
              "type": "number",
              "description": "成功率加权得分"
            },
            "business_value": {
              "type": "number",
              "description": "业务价值加权得分"
            },
            "maintenance_cost": {
              "type": "number",
              "description": "维护成本加权得分"
            },
            "risk_level": {
              "type": "number",
              "description": "风险等级加权得分"
            }
          },
          "description": "加权得分明细"
        }
      },
      "description": "综合评分"
    },
    "recommended_action": {
      "type": "string",
      "enum": ["keep", "optimize", "merge", "deprecate", "remove"],
      "description": "推荐动作"
    },
    "action_reason": {
      "type": "string",
      "description": "推荐动作原因"
    },
    "scoring_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "评分时间"
    },
    "next_review_date": {
      "type": "string",
      "format": "date-time",
      "description": "下次评审日期"
    }
  },
  "scoring_weights": {
    "usage_frequency": 0.25,
    "success_rate": 0.25,
    "business_value": 0.25,
    "maintenance_cost": 0.15,
    "risk_level": 0.10
  },
  "scoring_thresholds": {
    "keep": {
      "min_score": 70,
      "conditions": ["success_rate > 0.95", "risk_level != critical"]
    },
    "optimize": {
      "min_score": 50,
      "max_score": 70,
      "conditions": ["usage_frequency > 100/day"]
    },
    "merge": {
      "conditions": ["similar_skill_exists", "usage_frequency < 50/day"]
    },
    "deprecate": {
      "max_score": 50,
      "conditions": ["usage_frequency < 10/day", "better_alternative_exists"]
    },
    "remove": {
      "max_score": 30,
      "conditions": ["usage_frequency < 1/day", "no_active_users"]
    }
  },
  "category_thresholds": {
    "core": {
      "usage_frequency": "> 1000/day",
      "success_rate": "> 0.99",
      "business_value": "critical or important"
    },
    "high_freq": {
      "usage_frequency": "> 100/day",
      "success_rate": "> 0.95"
    },
    "standard": {
      "usage_frequency": "> 10/day",
      "success_rate": "> 0.90"
    },
    "experimental": {
      "status": "new or testing",
      "age": "< 3 months"
    },
    "low_value": {
      "usage_frequency": "< 10/day",
      "business_value": "low"
    },
    "deprecate": {
      "status": "planned_removal"
    }
  }
}
