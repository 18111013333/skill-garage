{
  "version": "1.0.0",
  "lastUpdated": "2026-04-06T11:29:00+08:00",
  "description": "测试数据结构定义",
  "schemas": {
    "test_case": {
      "fields": {
        "testId": { "type": "string", "required": true },
        "testName": { "type": "string", "required": true },
        "testType": { "type": "string", "enum": ["unit", "integration", "e2e", "regression"], "required": true },
        "description": { "type": "string", "required": true },
        "preconditions": { "type": "array", "required": false },
        "steps": { "type": "array", "required": true },
        "expectedResults": { "type": "array", "required": true },
        "timeout": { "type": "integer", "default": 30000 }
      }
    },
    "test_result": {
      "fields": {
        "testId": { "type": "string", "required": true },
        "timestamp": { "type": "string", "format": "date-time", "required": true },
        "status": { "type": "string", "enum": ["passed", "failed", "skipped"], "required": true },
        "duration": { "type": "integer", "required": true },
        "errorMessage": { "type": "string", "required": false },
        "stackTrace": { "type": "string", "required": false }
      }
    },
    "test_data": {
      "fields": {
        "dataId": { "type": "string", "required": true },
        "dataType": { "type": "string", "enum": ["input", "output", "mock", "fixture"], "required": true },
        "content": { "type": "object", "required": true },
        "tags": { "type": "array", "required": false }
      }
    }
  },
  "testDataTypes": {
    "input": {
      "description": "测试输入数据",
      "examples": ["用户输入", "API请求", "文件内容"]
    },
    "output": {
      "description": "预期输出数据",
      "examples": ["期望结果", "响应数据", "文件输出"]
    },
    "mock": {
      "description": "模拟数据",
      "examples": ["API响应", "数据库记录", "外部服务"]
    },
    "fixture": {
      "description": "测试固件",
      "examples": ["配置文件", "测试环境", "初始化数据"]
    }
  },
  "example": {
    "testCase": {
      "testId": "TC001",
      "testName": "test_user_login",
      "testType": "integration",
      "description": "测试用户登录功能",
      "preconditions": ["用户已注册"],
      "steps": [
        { "step": 1, "action": "输入用户名", "input": "test_user" },
        { "step": 2, "action": "输入密码", "input": "test_pass" },
        { "step": 3, "action": "点击登录", "input": null }
      ],
      "expectedResults": [
        { "step": 1, "result": "显示用户名" },
        { "step": 2, "result": "密码已隐藏" },
        { "step": 3, "result": "登录成功" }
      ],
      "timeout": 10000
    },
    "testData": {
      "dataId": "TD001",
      "dataType": "input",
      "content": {
        "username": "test_user",
        "password": "test_pass"
      },
      "tags": ["login", "auth"]
    }
  }
}
