{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tenant Policy Bundle",
  "description": "租户策略包配置",
  "type": "object",
  "required": ["tenant_id", "safety_mode", "autonomy_cap", "retention_policy"],
  "properties": {
    "tenant_id": {
      "type": "string",
      "description": "租户ID"
    },
    "bundle_name": {
      "type": "string",
      "description": "策略包名称"
    },
    "safety_mode": {
      "type": "string",
      "enum": ["strict", "standard", "relaxed", "custom"],
      "default": "standard",
      "description": "安全模式"
    },
    "citation_mode": {
      "type": "string",
      "enum": ["always", "on_request", "never"],
      "default": "on_request",
      "description": "引用模式"
    },
    "autonomy_cap": {
      "type": "string",
      "enum": ["none", "low", "medium", "high", "full"],
      "default": "medium",
      "description": "自主权限上限"
    },
    "retention_policy": {
      "type": "object",
      "description": "数据保留策略",
      "properties": {
        "memory_retention_days": {"type": "integer", "default": 365},
        "log_retention_days": {"type": "integer", "default": 90},
        "audit_retention_days": {"type": "integer", "default": 365},
        "backup_retention_days": {"type": "integer", "default": 30}
      }
    },
    "approval_defaults": {
      "type": "object",
      "description": "审批默认配置",
      "properties": {
        "auto_approve_threshold": {"type": "string", "enum": ["none", "low_risk", "standard"]},
        "escalation_timeout_hours": {"type": "integer", "default": 24},
        "require_mfa_for_sensitive": {"type": "boolean", "default": true}
      }
    },
    "integration_scope": {
      "type": "object",
      "description": "集成范围",
      "properties": {
        "allowed_integrations": {
          "type": "array",
          "items": {"type": "string"}
        },
        "blocked_integrations": {
          "type": "array",
          "items": {"type": "string"}
        },
        "require_approval": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "logging_level": {
      "type": "string",
      "enum": ["debug", "info", "warning", "error", "critical"],
      "default": "info"
    },
    "feature_flags": {
      "type": "object",
      "description": "功能开关",
      "properties": {
        "enable_advanced_search": {"type": "boolean", "default": true},
        "enable_multi_agent": {"type": "boolean", "default": false},
        "enable_external_api": {"type": "boolean", "default": false},
        "enable_custom_integrations": {"type": "boolean", "default": false},
        "enable_analytics": {"type": "boolean", "default": true},
        "enable_export": {"type": "boolean", "default": true}
      }
    },
    "rate_limits": {
      "type": "object",
      "description": "速率限制",
      "properties": {
        "api_calls_per_minute": {"type": "integer", "default": 100},
        "api_calls_per_day": {"type": "integer", "default": 10000},
        "concurrent_sessions": {"type": "integer", "default": 10},
        "storage_gb": {"type": "integer", "default": 100}
      }
    },
    "notification_settings": {
      "type": "object",
      "description": "通知设置",
      "properties": {
        "alert_channels": {
          "type": "array",
          "items": {"type": "string", "enum": ["email", "sms", "webhook", "in_app"]}
        },
        "digest_frequency": {"type": "string", "enum": ["realtime", "hourly", "daily", "weekly"]},
        "escalation_chain": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "compliance_settings": {
      "type": "object",
      "description": "合规设置",
      "properties": {
        "data_residency": {"type": "string"},
        "encryption_required": {"type": "boolean", "default": true},
        "audit_all_access": {"type": "boolean", "default": true},
        "pii_handling": {"type": "string", "enum": ["strict", "standard", "relaxed"]}
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string",
      "default": "1.0.0"
    }
  }
}
