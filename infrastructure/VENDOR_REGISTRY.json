{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VENDOR_REGISTRY",
  "description": "供应商/第三方台账，记录所有外部依赖的正式登记信息",
  "version": "1.0.0",
  "updated_at": "2026-04-07",
  
  "registry_metadata": {
    "total_vendors": 0,
    "critical_vendors": 0,
    "high_risk_vendors": 0,
    "last_audit_date": "2026-04-07",
    "next_review_date": "2026-07-07"
  },

  "vendor_schema": {
    "vendor_id": {
      "type": "string",
      "description": "供应商唯一标识符",
      "pattern": "^VENDOR-[A-Z0-9]{6}$"
    },
    "vendor_name": {
      "type": "string",
      "description": "供应商名称"
    },
    "vendor_type": {
      "type": "string",
      "enum": ["model_provider", "cloud_service", "sdk_library", "data_provider", "integration_service", "infrastructure", "security_service", "other"],
      "description": "供应商类型"
    },
    "services_used": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "service_name": {"type": "string"},
          "service_description": {"type": "string"},
          "usage_purpose": {"type": "string"},
          "data_exposure": {"type": "string", "enum": ["none", "minimal", "moderate", "high", "critical"]}
        }
      },
      "description": "使用的服务列表"
    },
    "trust_level": {
      "type": "string",
      "enum": ["untrusted", "low", "medium", "high", "verified"],
      "description": "信任级别"
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"],
      "description": "风险级别"
    },
    "data_exposure_scope": {
      "type": "object",
      "properties": {
        "user_data": {"type": "boolean"},
        "conversation_data": {"type": "boolean"},
        "system_data": {"type": "boolean"},
        "credential_data": {"type": "boolean"},
        "audit_data": {"type": "boolean"},
        "exposure_details": {"type": "string"}
      },
      "description": "数据暴露范围"
    },
    "contract_status": {
      "type": "string",
      "enum": ["pending", "active", "renewal_due", "terminated", "suspended"],
      "description": "合同状态"
    },
    "contract_dates": {
      "type": "object",
      "properties": {
        "start_date": {"type": "string", "format": "date"},
        "end_date": {"type": "string", "format": "date"},
        "renewal_date": {"type": "string", "format": "date"},
        "termination_notice_days": {"type": "integer"}
      }
    },
    "compliance_requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "requirement": {"type": "string"},
          "status": {"type": "string", "enum": ["pending", "compliant", "non_compliant", "not_applicable"]},
          "evidence": {"type": "string"},
          "last_check_date": {"type": "string", "format": "date"}
        }
      },
      "description": "合规要求"
    },
    "incident_contacts": {
      "type": "object",
      "properties": {
        "primary_contact": {
          "type": "object",
          "properties": {
            "name": {"type": "string"},
            "email": {"type": "string"},
            "phone": {"type": "string"},
            "available_24_7": {"type": "boolean"}
          }
        },
        "security_contact": {
          "type": "object",
          "properties": {
            "name": {"type": "string"},
            "email": {"type": "string"},
            "phone": {"type": "string"}
          }
        },
        "technical_contact": {
          "type": "object",
          "properties": {
            "name": {"type": "string"},
            "email": {"type": "string"},
            "phone": {"type": "string"}
          }
        }
      }
    },
    "sla_requirements": {
      "type": "object",
      "properties": {
        "uptime_sla": {"type": "number", "description": "正常运行时间 SLA 百分比"},
        "response_time_sla": {"type": "number", "description": "响应时间 SLA (ms)"},
        "support_response_sla": {"type": "string", "description": "支持响应 SLA"},
        "incident_resolution_sla": {"type": "string", "description": "事件解决 SLA"}
      }
    },
    "backup_and_alternatives": {
      "type": "object",
      "properties": {
        "has_backup": {"type": "boolean"},
        "backup_vendor_id": {"type": "string"},
        "fallback_strategy": {"type": "string"},
        "switch_over_time": {"type": "string", "description": "切换所需时间"}
      }
    },
    "security_assessment": {
      "type": "object",
      "properties": {
        "last_assessment_date": {"type": "string", "format": "date"},
        "assessment_result": {"type": "string", "enum": ["pass", "conditional_pass", "fail", "pending"]},
        "findings": {"type": "array", "items": {"type": "string"}},
        "next_assessment_date": {"type": "string", "format": "date"}
      }
    },
    "audit_trail": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "date": {"type": "string", "format": "date"},
          "action": {"type": "string"},
          "actor": {"type": "string"},
          "details": {"type": "string"}
        }
      }
    }
  },

  "vendors": [
    {
      "vendor_id": "VENDOR-000001",
      "vendor_name": "示例模型服务提供商",
      "vendor_type": "model_provider",
      "services_used": [
        {
          "service_name": "LLM API",
          "service_description": "大语言模型推理服务",
          "usage_purpose": "核心对话能力",
          "data_exposure": "moderate"
        }
      ],
      "trust_level": "high",
      "risk_level": "medium",
      "data_exposure_scope": {
        "user_data": false,
        "conversation_data": true,
        "system_data": false,
        "credential_data": false,
        "audit_data": false,
        "exposure_details": "对话内容用于模型推理，不存储"
      },
      "contract_status": "active",
      "contract_dates": {
        "start_date": "2025-01-01",
        "end_date": "2026-12-31",
        "renewal_date": "2026-09-30",
        "termination_notice_days": 90
      },
      "compliance_requirements": [
        {
          "requirement": "SOC2 Type II",
          "status": "compliant",
          "evidence": "审计报告 2025",
          "last_check_date": "2025-12-01"
        },
        {
          "requirement": "GDPR 合规",
          "status": "compliant",
          "evidence": "DPA 协议",
          "last_check_date": "2025-12-01"
        }
      ],
      "incident_contacts": {
        "primary_contact": {
          "name": "客户经理",
          "email": "support@example.com",
          "phone": "+1-xxx-xxx-xxxx",
          "available_24_7": true
        },
        "security_contact": {
          "name": "安全团队",
          "email": "security@example.com",
          "phone": "+1-xxx-xxx-xxxx"
        }
      },
      "sla_requirements": {
        "uptime_sla": 99.9,
        "response_time_sla": 500,
        "support_response_sla": "4 hours",
        "incident_resolution_sla": "24 hours"
      },
      "backup_and_alternatives": {
        "has_backup": true,
        "backup_vendor_id": "VENDOR-000002",
        "fallback_strategy": "自动切换到备用模型",
        "switch_over_time": "5 minutes"
      },
      "security_assessment": {
        "last_assessment_date": "2025-10-15",
        "assessment_result": "pass",
        "findings": [],
        "next_assessment_date": "2026-04-15"
      },
      "audit_trail": [
        {
          "date": "2025-01-01",
          "action": "vendor_onboarded",
          "actor": "procurement_team",
          "details": "完成供应商接入流程"
        }
      ]
    }
  ],

  "vendor_categories": {
    "model_provider": {
      "description": "模型服务提供商",
      "risk_weight": 1.2,
      "required_assessments": ["security", "privacy", "performance"]
    },
    "cloud_service": {
      "description": "云服务提供商",
      "risk_weight": 1.0,
      "required_assessments": ["security", "compliance"]
    },
    "sdk_library": {
      "description": "SDK/库提供商",
      "risk_weight": 0.8,
      "required_assessments": ["security"]
    },
    "data_provider": {
      "description": "数据提供商",
      "risk_weight": 1.5,
      "required_assessments": ["security", "privacy", "data_quality"]
    },
    "integration_service": {
      "description": "集成服务提供商",
      "risk_weight": 1.0,
      "required_assessments": ["security", "reliability"]
    },
    "infrastructure": {
      "description": "基础设施提供商",
      "risk_weight": 1.0,
      "required_assessments": ["security", "reliability", "compliance"]
    },
    "security_service": {
      "description": "安全服务提供商",
      "risk_weight": 1.3,
      "required_assessments": ["security", "compliance"]
    }
  },

  "trust_level_definitions": {
    "untrusted": {
      "description": "未验证或存在已知风险",
      "max_data_exposure": "none",
      "requires_approval": true,
      "review_frequency": "monthly"
    },
    "low": {
      "description": "基本验证通过，存在一定风险",
      "max_data_exposure": "minimal",
      "requires_approval": true,
      "review_frequency": "quarterly"
    },
    "medium": {
      "description": "验证通过，风险可控",
      "max_data_exposure": "moderate",
      "requires_approval": false,
      "review_frequency": "quarterly"
    },
    "high": {
      "description": "充分验证，长期合作",
      "max_data_exposure": "high",
      "requires_approval": false,
      "review_frequency": "semi_annually"
    },
    "verified": {
      "description": "最高信任级别，经过全面审计",
      "max_data_exposure": "critical",
      "requires_approval": false,
      "review_frequency": "annually"
    }
  },

  "risk_factors": {
    "data_exposure": {
      "weight": 0.3,
      "levels": {
        "none": 0,
        "minimal": 1,
        "moderate": 2,
        "high": 3,
        "critical": 4
      }
    },
    "service_criticality": {
      "weight": 0.25,
      "levels": {
        "optional": 1,
        "important": 2,
        "core": 3,
        "critical": 4
      }
    },
    "vendor_concentration": {
      "weight": 0.15,
      "description": "是否存在替代方案"
    },
    "compliance_status": {
      "weight": 0.15,
      "levels": {
        "fully_compliant": 1,
        "partially_compliant": 2,
        "non_compliant": 4
      }
    },
    "incident_history": {
      "weight": 0.15,
      "description": "历史安全事件"
    }
  },

  "compliance_checklist": [
    {
      "requirement": "数据保护协议 (DPA)",
      "applicable_types": ["model_provider", "data_provider", "cloud_service"],
      "mandatory": true
    },
    {
      "requirement": "安全审计报告",
      "applicable_types": ["model_provider", "cloud_service", "infrastructure", "security_service"],
      "mandatory": true
    },
    {
      "requirement": "隐私政策",
      "applicable_types": ["model_provider", "data_provider", "cloud_service"],
      "mandatory": true
    },
    {
      "requirement": "SLA 协议",
      "applicable_types": ["all"],
      "mandatory": true
    },
    {
      "requirement": "事件响应协议",
      "applicable_types": ["model_provider", "cloud_service", "infrastructure", "security_service"],
      "mandatory": true
    },
    {
      "requirement": "退出/数据返还协议",
      "applicable_types": ["model_provider", "data_provider", "cloud_service"],
      "mandatory": true
    }
  ],

  "review_schedule": {
    "routine_review": {
      "frequency": "quarterly",
      "scope": "all active vendors",
      "activities": ["contract_status_check", "sla_compliance", "incident_review"]
    },
    "risk_review": {
      "frequency": "monthly",
      "scope": "high and critical risk vendors",
      "activities": ["security_assessment", "compliance_check", "performance_review"]
    },
    "comprehensive_audit": {
      "frequency": "annually",
      "scope": "all vendors",
      "activities": ["full_assessment", "contract_renewal", "alternative_evaluation"]
    }
  }
}
