{
  "version": "1.0.0",
  "lastUpdated": "2026-04-06T11:12:00+08:00",
  "description": "告警配置",
  "rules": [
    {
      "id": "SYS001",
      "name": "系统健康度严重下降",
      "condition": "system_health_score < 70",
      "level": "CRITICAL",
      "cooldown": 300,
      "message": "系统健康度降至 {value}%"
    },
    {
      "id": "SYS002",
      "name": "系统健康度下降",
      "condition": "system_health_score < 85",
      "level": "WARNING",
      "cooldown": 900,
      "message": "系统健康度降至 {value}%"
    },
    {
      "id": "SYS003",
      "name": "内存接近上限",
      "condition": "memory_usage > 90",
      "level": "WARNING",
      "cooldown": 900,
      "message": "内存使用率达到 {value}%"
    },
    {
      "id": "SYS004",
      "name": "CPU负载过高",
      "condition": "cpu_usage > 80",
      "level": "WARNING",
      "cooldown": 900,
      "message": "CPU使用率达到 {value}%"
    },
    {
      "id": "EXEC001",
      "name": "执行连续失败",
      "condition": "consecutive_failures >= 3",
      "level": "WARNING",
      "cooldown": 900,
      "message": "连续执行失败 {value} 次"
    },
    {
      "id": "EXEC002",
      "name": "错误率过高",
      "condition": "error_rate > 50",
      "level": "CRITICAL",
      "cooldown": 300,
      "message": "执行错误率达到 {value}%"
    },
    {
      "id": "EXEC003",
      "name": "执行延迟过高",
      "condition": "avg_latency > 60000",
      "level": "WARNING",
      "cooldown": 900,
      "message": "平均执行延迟 {value}ms"
    },
    {
      "id": "SEC001",
      "name": "安全违规",
      "condition": "security_violation > 0",
      "level": "CRITICAL",
      "cooldown": 0,
      "message": "检测到安全违规"
    },
    {
      "id": "SEC002",
      "name": "权限拒绝频繁",
      "condition": "permission_denied > 5 in 1h",
      "level": "WARNING",
      "cooldown": 900,
      "message": "1小时内权限拒绝 {value} 次"
    },
    {
      "id": "RES001",
      "name": "Token预算接近上限",
      "condition": "token_budget_usage > 80",
      "level": "WARNING",
      "cooldown": 900,
      "message": "Token预算使用率 {value}%"
    }
  ],
  "levels": {
    "CRITICAL": {
      "responseTime": "immediate",
      "channels": ["message", "log", "email"],
      "escalation": true
    },
    "WARNING": {
      "responseTime": "1h",
      "channels": ["log", "aggregate"],
      "escalation": false
    },
    "INFO": {
      "responseTime": "none",
      "channels": ["log"],
      "escalation": false
    }
  },
  "notification": {
    "channels": {
      "message": {
        "enabled": true,
        "type": "xiaoyi-channel"
      },
      "log": {
        "enabled": true,
        "path": "alert/logs/"
      },
      "email": {
        "enabled": false,
        "recipients": []
      },
      "aggregate": {
        "enabled": true,
        "interval": "1h"
      }
    },
    "templates": {
      "CRITICAL": "🚨 [CRITICAL] {rule}: {message}",
      "WARNING": "⚠️ [WARNING] {rule}: {message}",
      "INFO": "ℹ️ [INFO] {rule}: {message}"
    },
    "rateLimit": {
      "CRITICAL": 300,
      "WARNING": 900,
      "INFO": 3600
    }
  },
  "suppression": {
    "enabled": true,
    "rules": [
      {
        "type": "cooldown",
        "description": "同规则冷却期内抑制"
      },
      {
        "type": "maintenance",
        "description": "维护窗口期抑制"
      },
      {
        "type": "dependency",
        "description": "依赖告警未恢复时抑制"
      }
    ]
  },
  "autoAction": {
    "enabled": true,
    "actions": [
      {
        "trigger": "memory_usage > 90",
        "action": "clear_cache"
      },
      {
        "trigger": "consecutive_failures >= 3",
        "action": "enter_degraded_mode"
      },
      {
        "trigger": "token_budget_usage > 90",
        "action": "throttle_requests"
      }
    ]
  }
}
