{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ASSET_SCHEMA",
  "description": "可分发资产对象定义",
  "version": "1.0.0",
  "updated_at": "2026-04-07T12:00:00+08:00",

  "asset_types": {
    "prompt_template": {
      "description": "提示词模板",
      "file_format": [".md", ".yaml", ".json"],
      "required_fields": ["template", "variables", "examples"]
    },
    "workflow": {
      "description": "工作流定义",
      "file_format": [".yaml", ".json"],
      "required_fields": ["steps", "triggers", "outputs"]
    },
    "playbook": {
      "description": "操作手册",
      "file_format": [".md", ".yaml"],
      "required_fields": ["procedures", "checklists"]
    },
    "report_template": {
      "description": "报告模板",
      "file_format": [".md", ".html", ".docx"],
      "required_fields": ["sections", "data_bindings"]
    },
    "connector_bundle": {
      "description": "连接器组合包",
      "file_format": [".json"],
      "required_fields": ["connectors", "config_template"]
    },
    "dashboard_pack": {
      "description": "仪表板包",
      "file_format": [".json"],
      "required_fields": ["widgets", "layout", "data_sources"]
    }
  },

  "asset_definition": {
    "required_fields": [
      "asset_id",
      "asset_type",
      "asset_name",
      "owner",
      "version",
      "tenant_visibility",
      "compatibility",
      "pricing_mode",
      "compliance_tags",
      "lifecycle_status"
    ],

    "field_definitions": {
      "asset_id": {
        "type": "string",
        "pattern": "^asset_[a-z0-9_]+$",
        "description": "资产唯一标识"
      },
      "asset_type": {
        "type": "string",
        "enum": ["prompt_template", "workflow", "playbook", "report_template", "connector_bundle", "dashboard_pack"],
        "description": "资产类型"
      },
      "asset_name": {
        "type": "string",
        "description": "资产显示名称"
      },
      "owner": {
        "type": "object",
        "properties": {
          "owner_id": {"type": "string"},
          "owner_type": {"enum": ["user", "team", "organization", "platform"]},
          "contact": {"type": "string"}
        }
      },
      "version": {
        "type": "string",
        "pattern": "^\\d+\\.\\d+\\.\\d+$",
        "description": "语义化版本号"
      },
      "tenant_visibility": {
        "type": "object",
        "properties": {
          "visibility": {"enum": ["public", "private", "organization", "enterprise"]},
          "allowed_tenants": {"type": "array", "items": {"type": "string"}},
          "excluded_tenants": {"type": "array", "items": {"type": "string"}}
        }
      },
      "compatibility": {
        "type": "object",
        "properties": {
          "min_platform_version": {"type": "string"},
          "max_platform_version": {"type": "string"},
          "required_connectors": {"type": "array", "items": {"type": "string"}},
          "required_skills": {"type": "array", "items": {"type": "string"}},
          "required_plans": {"type": "array", "items": {"type": "string"}},
          "supported_regions": {"type": "array", "items": {"type": "string"}}
        }
      },
      "pricing_mode": {
        "type": "object",
        "properties": {
          "type": {"enum": ["free", "subscription", "usage", "enterprise", "custom"]},
          "price": {"type": "number"},
          "currency": {"type": "string"},
          "billing_period": {"enum": ["monthly", "yearly", "one_time", "usage"]}
        }
      },
      "compliance_tags": {
        "type": "array",
        "items": {"enum": ["gdpr", "ccpa", "pipa", "soc2", "hipaa", "pci", "iso27001", "none"]},
        "description": "合规标签"
      },
      "lifecycle_status": {
        "type": "string",
        "enum": ["draft", "review", "published", "deprecated", "retired"],
        "description": "生命周期状态"
      }
    }
  },

  "assets": [
    {
      "asset_id": "asset_code_review_workflow",
      "asset_type": "workflow",
      "asset_name": "代码审查工作流",
      "owner": {
        "owner_id": "team_devtools",
        "owner_type": "team",
        "contact": "devtools@example.com"
      },
      "version": "1.0.0",
      "tenant_visibility": {
        "visibility": "public",
        "allowed_tenants": [],
        "excluded_tenants": []
      },
      "compatibility": {
        "min_platform_version": "9.0.0",
        "max_platform_version": "",
        "required_connectors": ["conn_github"],
        "required_skills": ["code-analysis"],
        "required_plans": ["standard", "premium", "enterprise"],
        "supported_regions": ["cn", "us", "eu"]
      },
      "pricing_mode": {
        "type": "free",
        "price": 0,
        "currency": "USD",
        "billing_period": "one_time"
      },
      "compliance_tags": ["none"],
      "lifecycle_status": "published"
    },
    {
      "asset_id": "asset_daily_report_template",
      "asset_type": "report_template",
      "asset_name": "每日工作报告模板",
      "owner": {
        "owner_id": "platform",
        "owner_type": "platform",
        "contact": "support@openclaw.ai"
      },
      "version": "2.1.0",
      "tenant_visibility": {
        "visibility": "public",
        "allowed_tenants": [],
        "excluded_tenants": []
      },
      "compatibility": {
        "min_platform_version": "8.0.0",
        "max_platform_version": "",
        "required_connectors": [],
        "required_skills": [],
        "required_plans": ["all"],
        "supported_regions": ["all"]
      },
      "pricing_mode": {
        "type": "free",
        "price": 0,
        "currency": "USD",
        "billing_period": "one_time"
      },
      "compliance_tags": ["none"],
      "lifecycle_status": "published"
    },
    {
      "asset_id": "asset_enterprise_security_pack",
      "asset_type": "connector_bundle",
      "asset_name": "企业安全连接器包",
      "owner": {
        "owner_id": "org_security",
        "owner_type": "organization",
        "contact": "security@example.com"
      },
      "version": "1.0.0",
      "tenant_visibility": {
        "visibility": "enterprise",
        "allowed_tenants": [],
