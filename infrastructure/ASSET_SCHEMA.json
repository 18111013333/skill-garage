        "currency": "USD",
        "billing_period": "monthly"
      },
      "compliance_tags": ["soc2", "iso27001"],
      "lifecycle_status": "published"
    }
  ],

  "lifecycle_transitions": {
    "draft": {"next": ["review"], "prev": []},
    "review": {"next": ["published", "draft"], "prev": ["draft"]},
    "published": {"next": ["deprecated"], "prev": ["review"]},
    "deprecated": {"next": ["retired", "published"], "prev": ["published"]},
    "retired": {"next": [], "prev": ["deprecated"]}
  }
}
