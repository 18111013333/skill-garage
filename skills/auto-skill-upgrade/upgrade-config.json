{
  "auto_upgrade": {
    "version": "3.0-ULTIMATE",
    "enable": true,
    "trigger_phrase": "自动升级",
    "stages": [
      {
        "stage_id": 1,
        "name": "🔍 全维度自动检测",
        "enable": true,
        "scripts": ["scan-skills.sh", "detect-conflicts.sh", "detect-redundancy.sh"],
        "enhancements": {
          "scan_scope": [
            "skill_conflict",
            "redundant_skill", 
            "dependency_missing",
            "version_compatibility",
            "permission_compliance",
            "security_vulnerability",
            "performance_bottleneck"
          ],
          "conflict_rating": {
            "enable": true,
            "levels": ["致命", "警告", "提示"],
            "auto_fix_priority": ["致命", "警告"],
            "auto_fix_strategy": "智能替换/兼容适配"
          },
          "redundant_detection": {
            "enable": true,
            "detect_function_overlap": true,
            "auto_archive_unused": true,
            "unused_threshold_days": 14,
            "auto_merge_duplicate_function": true
          },
          "real_time_monitor": {
            "enable": true,
            "auto_trigger_upgrade": true,
            "monitor_interval_minutes": 60
          },
          "report": {
            "output_path": "conflicts-report.md",
            "include_solution": true,
            "visualize": true,
            "auto_generate_fix_script": true
          }
        }
      },
      {
        "stage_id": 2,
        "name": "⚡ 极致性能优化",
        "enable": true,
        "scripts": ["performance-optimizer.sh", "token-monitor.sh", "lazy-loader.sh"],
        "enhancements": {
          "token_management": {
            "enable": true,
            "target_reduction": "30%",
            "methods": ["懒加载", "压缩", "缓存", "去冗余"],
            "monitor_real_time": true,
            "alert_threshold": "80%"
          },
          "speed_optimization": {
            "enable": true,
            "target_load_time": "<2s",
            "methods": ["并行加载", "预编译", "索引优化"],
            "benchmark_enabled": true
          },
          "resource_optimization": {
            "enable": true,
            "memory_limit": "512MB",
            "disk_cleanup": true,
            "cache_strategy": "LRU"
          },
          "experience_optimization": {
            "enable": true,
            "progressive_loading": true,
            "smart_preload": true,
            "background_optimization": true
          }
        }
      },
      {
        "stage_id": 3,
        "name": "🧠 智能记忆管理",
        "enable": true,
        "scripts": ["memory-compress.sh", "session-compress.sh", "update-ontology.sh", "learning-capture.sh"],
        "enhancements": {
          "memory_compression": {
            "enable": true,
            "compression_ratio": "50%",
            "archive_old_days": 30,
            "keep_essential": true
          },
          "session_management": {
            "enable": true,
            "max_active_sessions": 10,
            "auto_archive_after_hours": 24,
            "extract_key_decisions": true
          },
          "knowledge_graph": {
            "enable": true,
            "auto_update_entities": true,
            "relationship_inference": true,
            "conflict_resolution": "智能合并"
          },
          "learning_capture": {
            "enable": true,
            "auto_capture": true,
            "categories": ["成功经验", "失败教训", "用户偏好", "系统优化"],
            "priority_levels": ["高", "中", "低"]
          }
        }
      },
      {
        "stage_id": 4,
        "name": "🧹 深度冗余清理",
        "enable": true,
        "scripts": ["redundancy-cleanup.sh", "auto-cleanup.sh", "skill-pruner.sh"],
        "enhancements": {
          "cleanup_scope": [
            "重复技能",
            "未使用技能",
            "过期配置",
            "临时文件",
            "旧日志",
            "缓存数据"
          ],
          "auto_cleanup": {
            "enable": true,
            "schedule": "daily",
            "keep_recent_days": 7,
            "dry_run_first": true
          },
          "skill_pruning": {
            "enable": true,
            "prune_unused_days": 30,
            "keep_core_skills": true,
            "backup_before_prune": true
          },
          "report": {
            "output_path": "cleanup-report.md",
            "show_space_saved": true,
            "list_removed_items": true
          }
        }
      },
      {
        "stage_id": 5,
        "name": "🔄 智能整合升级",
        "enable": true,
        "scripts": ["merge-skills.sh", "skill-chain-merge.sh", "config-merge.sh", "usage-tracker.sh", "skill-recommender.sh"],
        "enhancements": {
          "skill_integration": {
            "enable": true,
            "auto_merge_similar": true,
            "build_chains": true,
            "priority_optimization": true
          },
          "chain_management": {
            "enable": true,
            "max_chain_depth": 5,
            "auto_optimize": true,
            "detect_circular": true
          },
          "config_sync": {
            "enable": true,
            "sync_to_memory": true,
            "backup_before_sync": true,
            "validate_config": true
          },
          "usage_tracking": {
            "enable": true,
            "track_all_skills": true,
            "update_priority_by_usage": true,
            "recommend_by_history": true
          }
        }
      },
      {
        "stage_id": 6,
        "name": "🌱 自我进化系统",
        "enable": true,
        "scripts": ["auto-evolve.sh", "ontology-optimize.sh"],
        "enhancements": {
          "self_evolution": {
            "enable": true,
            "learn_from_usage": true,
            "adapt_to_user": true,
            "optimize_automatically": true
          },
          "ontology_optimization": {
            "enable": true,
            "compress_entities": true,
            "infer_relationships": true,
            "remove_obsolete": true
          },
          "evolution_log": {
            "enable": true,
            "track_changes": true,
            "measure_improvement": true,
            "rollback_support": true
          }
        }
      },
      {
        "stage_id": 7,
        "name": "🏗️ 架构升级",
        "enable": true,
        "scripts": ["architecture-upgrade.sh"],
        "enhancements": {
          "system_architecture": {
            "enable": true,
            "check_core_files": true,
            "check_directory_structure": true,
            "auto_create_missing": true
          },
          "skill_architecture": {
            "enable": true,
            "analyze_categories": true,
            "check_chains": true,
            "validate_priorities": true
          },
          "memory_architecture": {
            "enable": true,
            "check_three_layers": true,
            "validate_ontology": true,
            "check_scenarios": true
          },
          "health_assessment": {
            "enable": true,
            "scoring_range": "0-100",
            "threshold_excellent": 90,
            "threshold_good": 70,
            "auto_fix_issues": true
          }
        }
      }
    ],
    "output_files": {
      "config": "skills-config.json",
      "inventory": "skills-inventory.json",
      "conflicts": "conflicts-report.md",
      "architecture": "architecture-report.md",
      "performance": "performance-report.md",
      "token": "token-report.md",
      "cleanup": "cleanup-report.md",
      "log_dir": "logs/"
    },
    "backup": {
      "enable": true,
      "backup_dir": "backups/",
      "keep_versions": 5,
      "auto_backup_before_upgrade": true
    },
    "rollback": {
      "enable": true,
      "auto_rollback_on_failure": true,
      "keep_rollback_points": 3
    }
  }
}
