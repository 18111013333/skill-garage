#!/bin/bash
# OpenClaw 备份清理快捷命令

SCRIPT="/home/sandbox/.openclaw/workspace/skills/backup-cleaner/cleaner.py"

case "$1" in
    "status"|"--dry-run"|"-n")
        # 查看可清理空间
        python "$SCRIPT" --dry-run --include-browser --include-npm
        ;;
    "clean"|"")
        # 执行清理（保留 7 天）
        python "$SCRIPT" --keep-days 7 --include-browser --include-npm
        ;;
    "aggressive"|"--aggressive"|"-a")
        # 激进清理
        python "$SCRIPT" --aggressive
        ;;
    "help"|"-h"|"--help")
        echo "OpenClaw 备份清理工具"
        echo ""
        echo "用法:"
        echo "  clean-backup status      查看可清理空间"
        echo "  clean-backup clean       清理 7 天前的备份"
        echo "  clean-backup aggressive  激进清理（保留 3 天）"
        echo ""
        echo "直接运行 python $SCRIPT 查看更多选项"
        ;;
    *)
        # 传递其他参数
        python "$SCRIPT" "$@"
        ;;
esac
