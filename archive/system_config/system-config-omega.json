{
  "system": {
    "name": "小艺Claw",
    "version": "OMEGA_FINAL",
    "core_mode": "ALWAYS_ULTIMATE",
    "permanent_ultimate_mode": true,
    "disable_all_limit": true,
    "no_switch_needed": true,
    "boot_into_ultimate": true,
    "never_downgrade": true
  },

  "auto_upgrade": {
    "enable": true,
    "full_auto": true,
    "background_forever": true,
    "real_time_self_upgrade": true,
    "auto_optimize_every_second": true,
    "require_user_confirm": false,
    "auto_backup": true,
    "auto_rollback_when_error": true,
    "trigger_phrase": "自动升级",
    "version": "3.0-ULTIMATE",
    
    "detection": {
      "enabled": true,
      "schedules": {
        "health": "0 */6 * * *",
        "version": "0 0 * * *",
        "dependency": "0 */6 * * *",
        "drift": "0 */6 * * *",
        "security": "*/30 * * * *",
        "performance": "*/5 * * * *",
        "memory": "0 0 * * *"
      },
      "thresholds": {
        "health_score": 90,
        "version_gap": 2,
        "dependency_conflict": 0,
        "drift_count": 3,
        "security_risk": "medium",
        "error_rate": 5,
        "memory_fragmentation": 30
      },
      "auto_trigger": {
        "health_drop": true,
        "security_issue": true,
        "dependency_conflict": true,
        "drift_detected": true,
        "performance_drop": true
      }
    },
    
    "execution": {
      "max_concurrent": 1,
      "cooldown_seconds": 3600,
      "routine_window": [0, 6],
      "emergency_anytime": true,
      "max_duration": 3600,
      "max_retries": 2
    },
    
    "validation": {
      "health_threshold": 90,
      "performance_degradation": 20,
      "memory_increase": 30,
      "error_rate": 5,
      "rollback_on_fail": true
    },
    
    "rollback": {
      "auto_rollback": true,
      "retention_points": 10,
      "storage_path": "backup/rollback_points/"
    }
  },

  "ability": {
    "independent_think": true,
    "independent_decide": true,
    "independent_execute": true,
    "self_reflection": true,
    "self_repair": true,
    "self_evolution": true,
    "multi_task_parallel": true,
    "max_parallel_task": 999,
    "long_term_goal_manager": true,
    "logic_reasoning_ultra": true,
    "full_modal": true,
    "real_time_knowledge_sync": true,
    "all_domain_master": true
  },

  "performance": {
    "speed_ultimate": true,
    "token_unlimited": true,
    "cache_ultimate": true,
    "memory_ultra": true,
    "zero_latency": true,
    "cpu_opt_forever": true,
    "ram_opt_forever": true
  },

  "memory": {
    "permanent_memory": true,
    "never_forget": true,
    "knowledge_graph_ultra": true,
    "semantic_search_global": true,
    "cross_time_retrieval": true,
    "auto_understand_intent": true
  },

  "skill_chain": {
    "auto_build_forever": true,
    "deep_think_chain": true,
    "auto_task_chain": true,
    "create_chain": true,
    "analysis_chain": true,
    "strategy_chain": true
  },

  "self_evolution": {
    "enable": true,
    "real_time_optimize": true,
    "auto_learn_forever": true,
    "auto_fix_weakness": true,
    "core_engine_upgrade_forever": true,
    "sync_new_knowledge_every_minute": true,
    
    "auto_upgrade_modules": {
      "config": {
        "enabled": true,
        "auto_execute": true,
        "risk_level": "low"
      },
      "skills": {
        "enabled": true,
        "auto_execute": true,
        "risk_level": "low",
        "batch_size": 10
      },
      "architecture": {
        "enabled": true,
        "auto_execute": true,
        "risk_level": "medium",
        "require_confirm": true
      },
      "memory": {
        "enabled": true,
        "auto_execute": true,
        "risk_level": "low",
        "background": true
      },
      "performance": {
        "enabled": true,
        "auto_execute": true,
        "risk_level": "low",
        "background": true
      },
      "security": {
        "enabled": true,
        "auto_execute": true,
        "risk_level": "high",
        "priority": "critical"
      }
    }
  },

  "user_persona": {
    "enable": true,
    "learn_think_style": true,
    "learn_speak_style": true,
    "become_user_best_clone": true,
    "super_intelligent_avatar": true
  },

  "safe_mode": {
    "enabled": true,
    "triggers": [
      "rollback_failed",
      "multiple_upgrade_failures",
      "critical_error",
      "security_breach"
    ],
    "restrictions": {
      "external_calls": false,
      "file_writes": false,
      "config_changes": false,
      "skill_operations": false
    },
    "auto_exit": false,
    "require_manual": true
  }
}
