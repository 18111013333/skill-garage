{
  "safe_paths": [
    "/home/sandbox/.openclaw/workspace",
    "/home/sandbox/.openclaw/workspace/repo",
    "/home/sandbox/.openclaw/workspace/skills",
    "/tmp",
    "/home/sandbox/.openclaw/workspace/memory"
  ],
  "dangerous_commands": [
    "rm",
    "sudo",
    "chmod",
    "chown",
    "mkfs",
    "dd",
    "fdisk",
    "shutdown",
    "reboot",
    "halt",
    "init",
    "systemctl"
  ],
  "dangerous_patterns": [
    "rm -rf /",
    "rm -rf /*",
    "> /dev/",
    "chmod 777",
    "chmod -R 777",
    ":(){ :|:& };:",
    "mkfs.ext4"
  ],
  "auth_timeout": 3600,
  "log_max_entries": 1000,
  "require_auth_for_write": true,
  "require_auth_for_exec": true
}
