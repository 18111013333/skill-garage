  "activation_rules": {
    "startup": {
      "description": "启动时激活",
      "layers": ["L0_core"],
      "priority": "P0"
    },
    "per_request": {
      "description": "每次请求激活",
      "layers": ["L1_runtime", "L2_safety_governance"],
      "priority": "P0"
    },
    "skill_router": {
      "description": "技能路由激活",
      "layers": ["L6_skills"],
      "priority": "P0",
      "router": "runtime/SKILL_ROUTER.json"
    },
    "continuous": {
      "description": "持续运行",
      "layers": ["L5_auto_optimization", "L9_evolution"],
      "priority": "P1"
    },
    "event_triggered": {
      "description": "事件触发",
      "mappings": {
        "security_event": ["L3_attack_defense"],
        "failure_event": ["L4_resilience"],
        "api_call": ["L7_developer_platform"],
        "business_event": ["L8_commercial"],
        "multiagent_task": ["L10_multiagent"],
        "vector_operation": ["L11_vector"],
        "creative_task": ["L12_creative"]
      }
