{
  "schema": "regulatory_response.request_intake.v1",
  "description": "监管/审计/客户审查请求结构",
  "version": "1.0.0",
  "updated": "2026-04-07",
  
  "request_structure": {
    "required_fields": {
      "request_id": {
        "type": "string",
        "description": "请求唯一标识",
        "format": "REQ-YYYYMMDD-NNN"
      },
      "requester_type": {
        "type": "string",
        "description": "请求方类型",
        "enum": ["regulator", "auditor", "customer", "partner", "internal"]
      },
      "requester_name": {
        "type": "string",
        "description": "请求方名称"
      },
      "request_date": {
        "type": "date",
        "description": "请求日期"
      },
      "scope": {
        "type": "string",
        "description": "检查范围",
        "enum": ["full", "security", "privacy", "compliance", "ai_governance", "financial", "operational"]
      },
      "due_date": {
        "type": "date",
        "description": "要求完成日期"
      },
      "sensitivity": {
        "type": "string",
        "description": "敏感级别",
        "enum": ["public", "internal", "confidential", "restricted"]
      },
      "requested_artifacts": {
        "type": "array",
        "description": "要求的证据材料",
        "items": {
          "type": "object",
          "properties": {
            "artifact_type": { "type": "string" },
            "description": { "type": "string" },
            "format": { "type": "string" },
            "time_range": { "type": "string" }
          }
        }
      },
      "owner": {
        "type": "string",
        "description": "负责处理人"
      },
      "status": {
        "type": "string",
        "description": "处理状态",
        "enum": ["received", "in_review", "evidence_collection", "drafting", "review", "approved", "submitted", "closed"]
      }
    },
    
    "optional_fields": {
      "background": {
        "type": "string",
        "description": "请求背景说明"
      },
      "priority": {
        "type": "string",
        "description": "优先级",
        "enum": ["normal", "high", "urgent"]
      },
      "response_package_ref": {
        "type": "string",
        "description": "响应包引用"
      },
      "notes": {
        "type": "array",
        "description": "处理备注",
        "items": {
          "type": "object",
          "properties": {
            "date": { "type": "string" },
            "author": { "type": "string" },
            "content": { "type": "string" }
          }
        }
      }
    }
  },
  
  "status_workflow": {
    "received": {
      "description": "已接收",
      "next": ["in_review"],
      "sla": "4 小时内确认"
    },
    "in_review": {
      "description": "评估中",
      "next": ["evidence_collection"],
      "sla": "1 天内完成评估"
    },
    "evidence_collection": {
      "description": "证据收集中",
      "next": ["drafting"],
      "sla": "根据范围确定"
    },
    "drafting": {
      "description": "起草响应",
      "next": ["review"],
      "sla": "根据复杂度"
    },
    "review": {
      "description": "审核中",
      "next": ["approved", "drafting"],
      "sla": "2 天内完成"
    },
    "approved": {
      "description": "已批准",
      "next": ["submitted"],
      "sla": "1 天内提交"
    },
    "submitted": {
      "description": "已提交",
      "next": ["closed"],
      "sla": "等待确认"
    },
    "closed": {
      "description": "已关闭",
      "next": [],
      "sla": "归档"
    }
  },
  
  "example_record": {
    "request_id": "REQ-20260407-001",
    "requester_type": "regulator",
    "requester_name": "XX 监管机构",
    "request_date": "2026-04-07",
    "scope": "ai_governance",
    "due_date": "2026-04-30",
    "sensitivity": "confidential",
    "requested_artifacts": [
      {
        "artifact_type": "policy",
        "description": "AI 治理政策文件",
        "format": "PDF",
        "time_range": "当前版本"
      },
      {
        "artifact_type": "log",
        "description": "AI 决策日志样本",
        "format": "JSON",
        "time_range": "近 3 个月"
      }
    ],
    "owner": "合规负责人",
    "status": "received",
    "priority": "high"
  }
}
