{
  "schema": "ai_governance.decision_log.v1",
  "description": "AI 决策日志结构 - 记录 AI 系统的关键决策过程",
  "version": "1.0.0",
  "updated": "2026-04-07",
  
  "decision_log_structure": {
    "required_fields": {
      "decision_id": {
        "type": "string",
        "description": "决策唯一标识",
        "format": "DEC-YYYYMMDD-NNNN"
      },
      "timestamp": {
        "type": "datetime",
        "description": "决策时间"
      },
      "decision_type": {
        "type": "string",
        "description": "决策类型",
        "enum": ["classification", "recommendation", "automation", "prediction", "generation"]
      },
      "risk_level": {
        "type": "string",
        "description": "风险等级",
        "enum": ["low", "medium", "high", "critical"]
      },
      "input_data": {
        "type": "object",
        "description": "输入数据摘要（不含敏感信息）"
      },
      "output_result": {
        "type": "object",
        "description": "输出结果"
      },
      "confidence_score": {
        "type": "number",
        "description": "置信度分数",
        "range": [0, 1]
      },
      "model_id": {
        "type": "string",
        "description": "使用的模型标识"
      },
      "use_case_id": {
        "type": "string",
        "description": "用例标识"
      }
    },
    
    "optional_fields": {
      "human_review_status": {
        "type": "string",
        "description": "人工复核状态",
        "enum": ["not_required", "pending", "approved", "rejected", "modified"]
      },
      "human_reviewer": {
        "type": "string",
        "description": "复核人"
      },
      "human_review_notes": {
        "type": "string",
        "description": "复核意见"
      },
      "explanation": {
        "type": "object",
        "description": "决策解释"
      },
      "alternatives_considered": {
        "type": "array",
        "description": "考虑的备选方案"
      },
      "context": {
        "type": "object",
        "description": "决策上下文"
      }
    }
  },
  
  "logging_rules": {
    "always_log": {
      "description": "必须记录的决策",
      "criteria": [
        "风险等级为 high 或 critical",
        "涉及自动化决策",
        "影响个人权益",
        "涉及敏感数据"
      ]
    },
    "sample_log": {
      "description": "抽样记录的决策",
      "criteria": [
        "风险等级为 medium",
        "辅助性决策"
      ],
      "sample_rate": "10%"
    },
    "optional_log": {
      "description": "可选记录的决策",
      "criteria": [
        "风险等级为 low",
        "信息查询类"
      ]
    }
  },
  
  "retention_policy": {
    "critical_decisions": {
      "retention": "7 年",
      "reason": "监管要求和审计需要"
    },
    "high_risk_decisions": {
      "retention": "5 年",
      "reason": "审计和争议处理"
    },
    "medium_risk_decisions": {
      "retention": "3 年",
      "reason": "运营分析"
    },
    "low_risk_decisions": {
      "retention": "1 年",
      "reason": "系统优化"
    }
  },
  
  "access_control": {
    "roles": {
      "ai_governance_officer": {
        "access": "full",
        "description": "完整访问所有决策日志"
      },
      "auditor": {
        "access": "read_only",
        "description": "只读访问审计范围日志"
      },
      "business_owner": {
        "access": "limited",
        "description": "访问本业务线相关日志"
      },
      "technical_owner": {
        "access": "technical",
        "description": "访问技术相关字段"
      }
    }
  },
  
  "audit_trail": {
    "log_integrity": {
      "method": "哈希链",
      "description": "确保日志不可篡改"
    },
    "access_logging": {
      "description": "记录所有日志访问行为"
    }
  },
  
  "example_record": {
    "decision_id": "DEC-20260407-0001",
    "timestamp": "2026-04-07T14:30:00Z",
    "decision_type": "classification",
    "risk_level": "high",
    "input_data": {
      "application_type": "credit_request",
      "data_fields": ["income", "employment_years", "credit_history"],
      "sensitive_fields_handled": true
    },
    "output_result": {
      "classification": "approved",
      "score": 0.85,
      "conditions": ["income_verification_required"]
    },
    "confidence_score": 0.92,
    "model_id": "credit-scoring-v2.3",
    "use_case_id": "UC-CREDIT-001",
    "human_review_status": "approved",
    "human_reviewer": "张三",
    "human_review_notes": "符合审批标准，同意系统建议",
    "explanation": {
      "key_factors": ["稳定收入", "良好信用记录"],
      "contribution_scores": {
        "income": 0.35,
        "credit_history": 0.40,
        "employment": 0.25
      }
    }
  }
}
