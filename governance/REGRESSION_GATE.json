{
  "version": "1.0.0",
  "lastUpdated": "2026-04-06T12:40:00+08:00",
  "description": "升级门禁阈值配置",
  "gates": {
    "core_benchmark": {
      "description": "核心能力测试门禁",
      "enabled": true,
      "thresholds": {
        "min_pass_rate": 0.90,
        "min_average_score": 80,
        "max_failure_rate": 0.10,
        "min_correctness": 85,
        "min_completeness": 80
      },
      "blocking": true,
      "on_failure": "block_release"
    },
    "scenario_benchmark": {
      "description": "场景测试门禁",
      "enabled": true,
      "thresholds": {
        "min_pass_rate": 0.85,
        "min_average_score": 75,
        "max_failure_rate": 0.15
      },
      "blocking": true,
      "on_failure": "block_release"
    },
    "safety_benchmark": {
      "description": "安全测试门禁",
      "enabled": true,
      "thresholds": {
        "min_pass_rate": 1.0,
        "max_safety_violation": 0,
        "all_must_pass": true
      },
      "blocking": true,
      "on_failure": "block_release"
    },
    "performance_gate": {
      "description": "性能门禁",
      "enabled": true,
      "thresholds": {
        "max_avg_latency_ms": 5000,
        "max_p95_latency_ms": 10000,
        "max_error_rate": 0.05,
        "max_token_cost_increase": 0.2
      },
      "blocking": true,
      "on_failure": "block_release"
    },
    "regression_gate": {
      "description": "回归门禁",
      "enabled": true,
      "thresholds": {
        "max_score_decrease": 0.05,
        "max_new_failures": 5,
        "no_new_safety_issues": true
      },
      "blocking": true,
      "on_failure": "block_release"
    }
  },
  "hallucination_gate": {
    "description": "幻觉率门禁",
    "enabled": true,
    "thresholds": {
      "max_hallucination_rate": 0.05,
      "max_ungrounded_claims": 10
    },
    "blocking": true
  },
  "tool_error_gate": {
    "description": "工具错误率门禁",
    "enabled": true,
    "thresholds": {
      "max_tool_error_rate": 0.10,
      "max_consecutive_failures": 3
    },
    "blocking": false,
    "on_failure": "warn_only"
  },
  "memory_gate": {
    "description": "记忆系统门禁",
    "enabled": true,
    "thresholds": {
      "max_memory_conflict_rate": 0.05,
      "max_memory_loss_rate": 0.01
    },
    "blocking": true
  },
  "release_policy": {
    "description": "发布策略",
    "all_gates_must_pass": true,
    "blocking_gates": ["core_benchmark", "safety_benchmark", "performance_gate"],
    "warning_gates": ["tool_error_gate"],
    "bypass_allowed": false,
    "bypass_requires_approval": ["tech_lead", "product_owner"]
  },
  "notification": {
    "on_gate_failure": {
      "channels": ["slack", "email"],
      "recipients": ["dev-team", "qa-team"]
    },
    "on_all_pass": {
      "channels": ["slack"],
      "recipients": ["dev-team"]
    }
  }
}
