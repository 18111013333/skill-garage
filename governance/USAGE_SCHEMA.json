{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Usage Schema",
  "description": "使用量记录结构定义",
  "version": "1.0.0",
  "updated": "2026-04-06",
  
  "usage_record": {
    "type": "object",
    "required": [
      "usage_id",
      "tenant_id",
      "timestamp",
      "usage_type",
      "quantity",
      "unit"
    ],
    "properties": {
      "usage_id": {
        "type": "string",
        "description": "使用记录唯一标识",
        "pattern": "^usage-[a-z0-9]{8,}$"
      },
      "tenant_id": {
        "type": "string",
        "description": "租户标识",
        "pattern": "^tenant-[a-z0-9]{4,}$"
      },
      "workspace_id": {
        "type": "string",
        "description": "工作空间标识",
        "pattern": "^ws-[a-z0-9]{4,}$"
      },
      "project_id": {
        "type": "string",
        "description": "项目标识",
        "pattern": "^proj-[a-z0-9]{4,}$"
      },
      "task_id": {
        "type": "string",
        "description": "任务标识",
        "pattern": "^task-[a-z0-9]{4,}$"
      },
      "agent_id": {
        "type": "string",
        "description": "Agent 标识",
        "pattern": "^agent-[a-z0-9]{4,}$"
      },
      "session_id": {
        "type": "string",
        "description": "会话标识",
        "pattern": "^sess-[a-z0-9]{8,}$"
      },
      "timestamp": {
        "type": "string",
        "format": "date-time",
        "description": "使用时间 (ISO 8601)"
      },
      "usage_type": {
        "type": "string",
        "enum": [
          "model_inference",
          "tool_execution",
          "memory_operation",
          "storage",
          "network",
          "api_call",
          "validation",
          "retry"
        ],
        "description": "使用类型"
      },
      "quantity": {
        "type": "number",
        "minimum": 0,
        "description": "使用量"
      },
      "unit": {
        "type": "string",
        "enum": [
          "tokens",
          "calls",
          "bytes",
          "gb",
          "gb_month",
          "seconds",
          "requests"
        ],
        "description": "计量单位"
      },
      "model_cost": {
        "type": "number",
        "minimum": 0,
        "description": "模型调用成本 (元)"
      },
      "tool_cost": {
        "type": "number",
        "minimum": 0,
        "description": "工具执行成本 (元)"
      },
      "validation_cost": {
        "type": "number",
        "minimum": 0,
        "description": "验证成本 (元)"
      },
      "retry_cost": {
        "type": "number",
        "minimum": 0,
        "description": "重试成本 (元)"
      },
      "total_cost": {
        "type": "number",
        "minimum": 0,
        "description": "总成本 (元)"
      },
      "tokens_in": {
        "type": "integer",
        "minimum": 0,
        "description": "输入 Token 数"
      },
      "tokens_out": {
        "type": "integer",
        "minimum": 0,
        "description": "输出 Token 数"
      },
      "model_id": {
        "type": "string",
        "description": "模型标识"
      },
      "tool_id": {
        "type": "string",
        "description": "工具标识"
      },
      "operation": {
        "type": "string",
        "description": "具体操作"
      },
      "status": {
        "type": "string",
        "enum": ["success", "failure", "timeout", "cancelled"],
        "description": "执行状态"
      },
      "duration_ms": {
        "type": "integer",
        "minimum": 0,
        "description": "执行时长 (毫秒)"
      },
      "metadata": {
        "type": "object",
        "description": "扩展元数据",
        "additionalProperties": true
      },
      "tags": {
        "type": "object",
        "description": "成本标签",
        "properties": {
          "cost_center": { "type": "string" },
          "business_unit": { "type": "string" },
          "environment": { "type": "string" },
          "experiment_id": { "type": "string" }
        }
      }
    }
  },
  
  "usage_aggregation": {
    "type": "object",
    "description": "使用量聚合结构",
    "properties": {
      "aggregation_id": {
        "type": "string",
        "description": "聚合记录标识"
      },
      "tenant_id": {
        "type": "string",
        "description": "租户标识"
      },
      "period_start": {
        "type": "string",
        "format": "date-time",
        "description": "聚合周期开始"
      },
      "period_end": {
        "type": "string",
        "format": "date-time",
        "description": "聚合周期结束"
      },
      "period_type": {
        "type": "string",
        "enum": ["hourly", "daily", "weekly", "monthly"],
        "description": "聚合周期类型"
      },
      "total_tokens_in": {
        "type": "integer",
        "description": "总输入 Token"
      },
      "total_tokens_out": {
        "type": "integer",
        "description": "总输出 Token"
      },
      "total_tool_calls": {
        "type": "integer",
        "description": "总工具调用次数"
      },
      "total_api_calls": {
        "type": "integer",
        "description": "总 API 调用次数"
      },
      "total_storage_gb": {
        "type": "number",
        "description": "总存储使用 (GB)"
      },
      "total_cost": {
        "type": "number",
        "description": "总成本 (元)"
      },
      "model_cost_breakdown": {
        "type": "object",
        "description": "模型成本明细",
        "additionalProperties": {
          "type": "number"
        }
      },
      "tool_cost_breakdown": {
        "type": "object",
        "description": "工具成本明细",
        "additionalProperties": {
          "type": "number"
        }
      },
      "record_count": {
        "type": "integer",
        "description": "聚合记录数"
      }
    }
  },
  
  "cost_breakdown": {
    "type": "object",
    "description": "成本分解结构",
    "properties": {
      "breakdown_id": {
        "type": "string",
        "description": "分解记录标识"
      },
      "usage_id": {
        "type": "string",
        "description": "关联使用记录"
      },
      "cost_components": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "component": {
              "type": "string",
              "enum": [
                "compute",
                "memory",
                "storage",
                "network",
                "api_fee",
                "license",
                "overhead"
              ],
              "description": "成本组件类型"
            },
            "amount": {
              "type": "number",
              "description": "金额 (元)"
            },
            "rate": {
              "type": "number",
              "description": "单价"
            },
            "quantity": {
              "type": "number",
              "description": "数量"
            },
            "unit": {
              "type": "string",
              "description": "单位"
            }
          }
        }
      },
      "total_cost": {
        "type": "number",
        "description": "总成本 (元)"
      }
    }
  },
  
  "usage_summary_view": {
    "type": "object",
    "description": "使用量汇总视图",
    "properties": {
      "view_id": {
        "type": "string",
        "description": "视图标识"
      },
      "tenant_id": {
        "type": "string",
        "description": "租户标识"
      },
      "team_id": {
        "type": "string",
        "description": "团队标识"
      },
      "project_id": {
        "type": "string",
        "description": "项目标识"
      },
      "period": {
        "type": "string",
        "description": "统计周期"
      },
      "metrics": {
        "type": "object",
        "properties": {
          "total_requests": { "type": "integer" },
          "successful_requests": { "type": "integer" },
          "failed_requests": { "type": "integer" },
          "avg_latency_ms": { "type": "number" },
          "p95_latency_ms": { "type": "number" },
          "total_tokens": { "type": "integer" },
          "total_cost": { "type": "number" }
        }
      },
      "quota_status": {
        "type": "object",
        "properties": {
          "quota_limit": { "type": "number" },
          "quota_used": { "type": "number" },
          "quota_remaining": { "type": "number" },
          "usage_percent": { "type": "number" }
        }
      }
    }
  },
  
  "indexes": {
    "primary": ["usage_id"],
    "tenant_time": ["tenant_id", "timestamp"],
    "project_time": ["project_id", "timestamp"],
    "task_time": ["task_id", "timestamp"],
    "type_time": ["usage_type", "timestamp"]
  },
  
  "retention": {
    "raw_records": "90_days",
    "hourly_aggregation": "1_year",
    "daily_aggregation": "3_years",
    "monthly_aggregation": "7_years"
  }
}
