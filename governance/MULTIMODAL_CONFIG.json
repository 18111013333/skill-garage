{
  "module": "multimodal",
  "version": "1.0.0",
  "description": "多模态融合处理系统",
  "modalities": {
    "text": {
      "enabled": true,
      "priority": 1
    },
    "image": {
      "enabled": true,
      "priority": 2,
      "formats": [
        "jpg",
        "png",
        "gif",
        "webp",
        "svg"
      ]
    },
    "audio": {
      "enabled": true,
      "priority": 3,
      "formats": [
        "mp3",
        "wav",
        "m4a",
        "flac"
      ]
    },
    "video": {
      "enabled": true,
      "priority": 4,
      "formats": [
        "mp4",
        "webm",
        "mov",
        "avi"
      ]
    }
  },
  "cross_modal": {
    "text_to_image": true,
    "image_to_text": true,
    "audio_to_text": true,
    "video_to_text": true
  },
  "performance": {
    "text_latency_ms": 10,
    "image_latency_ms": 100,
    "audio_latency_ms": 200,
    "video_latency_ms": 500
  }
}