{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Role Schema",
  "description": "角色对象正式建模 - 终极鸽子王 V27.0",
  "version": "1.0.0",
  "type": "object",
  "required": ["role_id", "role_name", "scope", "permissions", "created_at"],
  "properties": {
    "role_id": {
      "type": "string",
      "description": "角色唯一标识符",
      "pattern": "^role_[a-zA-Z0-9]{16}$"
    },
    "role_name": {
      "type": "string",
      "description": "角色名称",
      "minLength": 1,
      "maxLength": 128
    },
    "role_code": {
      "type": "string",
      "description": "角色代码（用于API、配置等）",
      "pattern": "^[a-z_]{3,64}$"
    },
    "description": {
      "type": "string",
      "description": "角色描述",
      "maxLength": 1024
    },
    "scope": {
      "type": "string",
      "enum": ["system", "tenant", "project", "task", "resource"],
      "description": "角色作用域"
    },
    "scope_id": {
      "type": "string",
      "description": "作用域ID（如 tenant_id, project_id）"
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action", "resource"],
        "properties": {
          "action": {
            "type": "string",
            "enum": ["read", "comment", "propose", "execute", "approve", "configure", "export", "delete", "admin"],
            "description": "允许的动作"
          },
          "resource": {
            "type": "string",
            "enum": ["memory", "knowledge", "project", "portfolio", "config", "logs", "integrations", "reports", "users", "roles", "tenants", "skills", "events", "all"],
            "description": "目标资源"
          },
          "conditions": {
            "type": "object",
            "properties": {
              "own_only": { "type": "boolean", "description": "仅限自己创建的" },
              "time_restricted": { "type": "string", "description": "时间限制" },
              "ip_restricted": { "type": "array", "items": { "type": "string" }, "description": "IP限制" },
              "approval_required": { "type": "boolean", "description": "需要审批" }
            },
            "description": "权限条件"
          }
        }
      },
      "description": "权限列表"
    },
    "inherited_roles": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "role_id": { "type": "string" },
          "inherit_type": {
            "type": "string",
            "enum": ["full", "permissions_only", "conditions_only"]
          }
        }
      },
      "description": "继承的角色"
    },
    "restrictions": {
      "type": "object",
      "properties": {
        "max_sessions": { "type": "integer", "minimum": 1 },
        "max_concurrent_tasks": { "type": "integer", "minimum": 1 },
        "allowed_hours": {
          "type": "object",
          "properties": {
            "start": { "type": "string", "pattern": "^[0-2][0-9]:[0-5][0-9]$" },
            "end": { "type": "string", "pattern": "^[0-2][0-9]:[0-5][0-9]$" }
          }
        },
        "allowed_days": {
          "type": "array",
          "items": { "type": "string", "enum": ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"] }
        },
        "ip_whitelist": {
          "type": "array",
          "items": { "type": "string" }
        },
        "mfa_required": { "type": "boolean" },
        "session_timeout_minutes": { "type": "integer", "minimum": 5 }
      },
      "description": "角色限制"
    },
    "approval_power": {
      "type": "object",
      "properties": {
        "can_approve_actions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "可审批的动作"
        },
        "can_approve_resources": {
          "type": "array",
          "items": { "type": "string" },
          "description": "可审批的资源"
        },
        "approval_limits": {
          "type": "object",
          "additionalProperties": { "type": "number" },
          "description": "审批限额（如金额、数量）"
        },
        "delegation_allowed": { "type": "boolean" },
        "max_delegation_depth": { "type": "integer", "minimum": 1 }
      },
      "description": "审批权力"
    },
    "audit_requirements": {
      "type": "object",
      "properties": {
        "log_all_actions": { "type": "boolean" },
        "log_sensitive_access": { "type": "boolean" },
        "retention_days": { "type": "integer", "minimum": 30 },
        "alert_on_suspicious": { "type": "boolean" },
        "require_justification": {
          "type": "array",
          "items": { "type": "string" },
          "description": "需要填写理由的操作"
        }
      },
      "description": "审计要求"
    },
    "is_system_role": {
      "type": "boolean",
      "description": "是否系统内置角色"
    },
    "is_assignable": {
      "type": "boolean",
      "description": "是否可分配给用户"
    },
    "max_assignments": {
      "type": "integer",
      "description": "最大分配数量（0表示无限制）"
    },
    "assignment_requires_approval": {
      "type": "boolean",
      "description": "分配是否需要审批"
    },
    "status": {
      "type": "string",
      "enum": ["active", "deprecated", "disabled"],
      "description": "角色状态"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "创建时间"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "更新时间"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "扩展元数据"
    }
  },
  "system_roles": {
    "system_admin": {
      "description": "系统管理员",
      "scope": "system",
      "permissions": [
        { "action": "admin", "resource": "all" }
      ],
      "is_system_role": true,
      "is_assignable": true,
      "max_assignments": 5
    },
    "tenant_admin": {
      "description": "租户管理员",
      "scope": "tenant",
      "permissions": [
        { "action": "admin", "resource": "memory" },
        { "action": "admin", "resource": "knowledge" },
        { "action": "admin", "resource": "project" },
        { "action": "admin", "resource": "users" },
        { "action": "admin", "resource": "roles" },
        { "action": "admin", "resource": "config" }
      ],
      "is_system_role": true,
      "is_assignable": true
    },
    "project_owner": {
      "description": "项目所有者",
      "scope": "project",
      "permissions": [
        { "action": "admin", "resource": "project" },
        { "action": "admin", "resource": "memory" },
        { "action": "admin", "resource": "knowledge" }
      ],
      "is_system_role": true,
      "is_assignable": true
    },
    "project_member": {
      "description": "项目成员",
      "scope": "project",
      "permissions": [
        { "action": "read", "resource": "project" },
        { "action": "execute", "resource": "memory" },
        { "action": "execute", "resource": "knowledge" },
        { "action": "comment", "resource": "project" }
      ],
      "is_system_role": true,
      "is_assignable": true
    },
    "observer": {
      "description": "观察者",
      "scope": "project",
      "permissions": [
        { "action": "read", "resource": "project" },
        { "action": "read", "resource": "memory" },
        { "action": "read", "resource": "knowledge" }
      ],
      "is_system_role": true,
      "is_assignable": true
    },
    "approver": {
      "description": "审批者",
      "scope": "project",
      "permissions": [
        { "action": "read", "resource": "all" },
        { "action": "approve", "resource": "all" }
      ],
      "approval_power": {
        "can_approve_actions": ["execute", "configure", "delete"],
        "delegation_allowed": true,
        "max_delegation_depth": 2
      },
      "is_system_role": true,
      "is_assignable": true
    }
  },
  "permission_actions": {
    "read": { "description": "读取/查看", "risk_level": "low" },
    "comment": { "description": "评论/反馈", "risk_level": "low" },
    "propose": { "description": "提议/建议", "risk_level": "medium" },
    "execute": { "description": "执行/操作", "risk_level": "medium" },
    "approve": { "description": "审批/批准", "risk_level": "high" },
    "configure": { "description": "配置/设置", "risk_level": "high" },
    "export": { "description": "导出/下载", "risk_level": "medium" },
    "delete": { "description": "删除/销毁", "risk_level": "critical" },
    "admin": { "description": "完全管理", "risk_level": "critical" }
  },
  "permission_resources": {
    "memory": { "description": "记忆数据", "sensitivity": "high" },
    "knowledge": { "description": "知识库", "sensitivity": "medium" },
    "project": { "description": "项目", "sensitivity": "medium" },
    "portfolio": { "description": "项目组合", "sensitivity": "medium" },
    "config": { "description": "配置", "sensitivity": "high" },
    "logs": { "description": "日志", "sensitivity": "high" },
    "integrations": { "description": "集成", "sensitivity": "high" },
    "reports": { "description": "报表", "sensitivity": "medium" },
    "users": { "description": "用户", "sensitivity": "critical" },
    "roles": { "description": "角色", "sensitivity": "critical" },
    "tenants": { "description": "租户", "sensitivity": "critical" },
    "skills": { "description": "技能", "sensitivity": "medium" },
    "events": { "description": "事件", "sensitivity": "medium" },
    "all": { "description": "所有资源", "sensitivity": "critical" }
  },
  "validation_rules": {
    "permission_conflict_check": true,
    "inheritance_cycle_check": true,
    "scope_validity_check": true,
    "restriction_feasibility_check": true
  }
}
