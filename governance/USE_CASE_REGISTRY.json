{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Use Case Registry",
  "description": "AI 用例注册表",
  "type": "object",
  "required": ["use_case_id", "use_case_name", "business_owner", "risk_level", "approval_status"],
  "properties": {
    "use_case_id": {
      "type": "string",
      "description": "用例唯一标识",
      "pattern": "^uc_[a-z0-9_]+$"
    },
    "use_case_name": {
      "type": "string",
      "description": "用例名称",
      "minLength": 1,
      "maxLength": 100
    },
    "description": {
      "type": "string",
      "description": "用例描述"
    },
    "business_owner": {
      "type": "string",
      "description": "业务负责人"
    },
    "technical_owner": {
      "type": "string",
      "description": "技术负责人"
    },
    "risk_level": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"],
      "description": "风险等级"
    },
    "tenant_scope": {
      "type": "array",
      "description": "适用租户范围",
      "items": {
        "type": "string"
      }
    },
    "model_dependencies": {
      "type": "array",
      "description": "依赖的模型",
      "items": {
        "type": "object",
        "properties": {
          "model_id": {"type": "string"},
          "model_name": {"type": "string"},
          "provider": {"type": "string"}
        }
      }
    },
    "data_classes": {
      "type": "array",
      "description": "涉及的数据类别",
      "items": {
        "type": "string",
        "enum": ["public", "internal", "confidential", "restricted", "pii", "sensitive"]
      }
    },
    "human_oversight_mode": {
      "type": "string",
      "enum": ["full_manual", "human_in_loop", "human_on_loop", "full_auto"],
      "description": "人类监督模式"
    },
    "oversight_requirements": {
      "type": "object",
      "description": "监督要求",
      "properties": {
        "review_frequency": {"type": "string"},
        "reviewer_role": {"type": "string"},
        "escalation_threshold": {"type": "string"}
      }
    },
    "approval_status": {
      "type": "string",
      "enum": ["draft", "pending", "approved", "rejected", "suspended", "retired"],
      "default": "draft"
    },
    "approval_history": {
      "type": "array",
      "description": "审批历史",
      "items": {
        "type": "object",
        "properties": {
          "approval_id": {"type": "string"},
          "approver": {"type": "string"},
          "decision": {"type": "string"},
          "decision_date": {"type": "string", "format": "date-time"},
          "conditions": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "review_cycle": {
      "type": "object",
      "description": "复审周期",
      "properties": {
        "frequency": {
          "type": "string",
          "enum": ["monthly", "quarterly", "semiannually", "annually"]
        },
        "next_review": {"type": "string", "format": "date"},
        "last_review": {"type": "string", "format": "date"}
      }
    },
    "performance_metrics": {
      "type": "array",
      "description": "性能指标",
      "items": {
        "type": "object",
        "properties": {
          "metric_name": {"type": "string"},
          "target": {"type": "string"},
          "current": {"type": "string"}
        }
      }
    },
    "incident_history": {
      "type": "array",
      "description": "事故历史",
      "items": {
        "type": "object",
        "properties": {
          "incident_id": {"type": "string"},
          "date": {"type": "string", "format": "date"},
          "severity": {"type": "string"},
          "resolution": {"type": "string"}
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["active", "inactive", "testing", "deprecated"],
      "default": "active"
    }
  }
}
