{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Policy Catalog",
  "description": "全局策略目录 - 终极鸽子王 V27.0",
  "version": "1.0.0",
  "type": "object",
  "properties": {
    "catalog_version": {
      "type": "string",
      "description": "目录版本"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time",
      "description": "最后更新时间"
    },
    "policies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["policy_id", "domain", "scope", "owner", "severity", "version"],
        "properties": {
          "policy_id": {
            "type": "string",
            "description": "策略唯一标识符",
            "pattern": "^policy_[a-zA-Z0-9_]+$"
          },
          "policy_name": {
            "type": "string",
            "description": "策略名称"
          },
          "domain": {
            "type": "string",
            "enum": [
              "runtime",
              "safety",
              "governance",
              "compliance",
              "audit",
              "privacy",
              "data_governance",
              "model_governance",
              "evidence",
              "reporting",
              "tenancy",
              "access",
              "collaboration",
              "events",
              "knowledge",
              "incident",
              "skills",
              "evolution",
              "customer_success",
              "delivery",
              "partner",
              "api_product",
              "sdk",
              "connectors",
              "marketplace"
            ],
            "description": "策略领域"
          },
          "scope": {
            "type": "string",
            "enum": ["global", "tenant", "project", "user", "resource"],
            "description": "策略作用域"
          },
          "scope_id": {
            "type": "string",
            "description": "作用域ID（如适用）"
          },
          "owner": {
            "type": "object",
            "properties": {
              "owner_id": { "type": "string" },
              "owner_name": { "type": "string" },
              "owner_team": { "type": "string" },
              "contact": { "type": "string" }
            },
            "description": "策略负责人"
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "info"],
            "description": "策略严重等级"
          },
          "version": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
            "description": "策略版本"
          },
          "status": {
            "type": "string",
            "enum": ["active", "draft", "deprecated", "archived"],
            "default": "active",
            "description": "策略状态"
          },
          "effective_date": {
            "type": "string",
            "format": "date-time",
            "description": "生效日期"
          },
          "expiry_date": {
            "type": "string",
            "format": "date-time",
            "description": "过期日期"
          },
          "rollout_mode": {
            "type": "string",
            "enum": ["immediate", "gradual", "opt-in", "opt-out"],
            "default": "immediate",
            "description": "发布模式"
          },
          "linked_modules": {
            "type": "array",
            "items": { "type": "string" },
            "description": "关联模块列表"
          },
          "linked_policies": {
            "type": "array",
            "items": { "type": "string" },
            "description": "关联策略列表"
          },
          "review_cycle": {
            "type": "string",
            "enum": ["monthly", "quarterly", "semi-annually", "annually"],
            "default": "quarterly",
            "description": "评审周期"
          },
          "last_review": {
            "type": "string",
            "format": "date-time",
            "description": "上次评审时间"
          },
          "next_review": {
            "type": "string",
            "format": "date-time",
            "description": "下次评审时间"
          },
          "compliance_requirements": {
            "type": "array",
            "items": { "type": "string" },
            "description": "合规要求"
          },
          "enforcement": {
            "type": "object",
            "properties": {
              "enforcement_mode": {
                "type": "string",
                "enum": ["strict", "moderate", "advisory"],
                "description": "执行模式"
              },
              "violation_action": {
                "type": "string",
                "enum": ["block", "alert", "log", "none"],
                "description": "违规处理"
              },
              "exception_process": {
                "type": "string",
                "description": "例外处理流程"
              }
            },
            "description": "执行配置"
          },
          "metrics": {
            "type": "object",
            "properties": {
              "compliance_rate": { "type": "number" },
              "violation_count": { "type": "number" },
              "exception_count": { "type": "number" }
            },
            "description": "策略指标"
          },
          "document_ref": {
            "type": "string",
            "description": "策略文档引用"
          },
          "change_history": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "version": { "type": "string" },
                "change_date": { "type": "string", "format": "date-time" },
                "change_type": { "type": "string" },
                "change_description": { "type": "string" },
                "changed_by": { "type": "string" }
              }
            },
            "description": "变更历史"
          }
        }
      },
      "description": "策略列表"
    }
  },
  "policy_domains": {
    "runtime": {
      "description": "运行时策略",
      "policy_count": 35,
      "critical_policies": ["ORCHESTRATOR", "EXECUTION_POLICY", "STOP_RULES"]
    },
    "safety": {
      "description": "安全策略",
      "policy_count": 35,
      "critical_policies": ["RISK_POLICY", "BOUNDARY", "TOOL_GUARDRAILS"]
    },
    "governance": {
      "description": "治理策略",
      "policy_count": 10,
      "critical_policies": ["AUDIT_LOG", "MEMORY_POLICY", "POLICY_PRECEDENCE"]
    },
    "compliance": {
      "description": "合规策略",
      "policy_count": 4,
      "critical_policies": ["COMPLIANCE_FRAMEWORK"]
    },
    "tenancy": {
      "description": "租户策略",
      "policy_count": 2,
      "critical_policies": ["TENANT_ISOLATION"]
    },
    "access": {
      "description": "访问控制策略",
      "policy_count": 3,
      "critical_policies": ["RBAC_POLICY", "PERMISSION_MATRIX"]
    },
    "evolution": {
      "description": "进化策略",
      "policy_count": 3,
      "critical_policies": ["EVOLUTION_GATES", "EVOLUTION_IMPACT_ANALYSIS"]
    },
    "incident": {
      "description": "事故策略",
      "policy_count": 3,
      "critical_policies": ["INCIDENT_RESPONSE", "ESCALATION_MATRIX"]
    },
    "skills": {
      "description": "技能策略",
      "policy_count": 3,
      "critical_policies": ["SKILL_PORTFOLIO_MANAGEMENT", "SKILL_DEPRECATION_POLICY"]
    }
  },
  "severity_definitions": {
    "critical": {
      "description": "关键策略",
      "violation_impact": "严重业务影响",
      "review_cycle": "monthly"
    },
    "high": {
      "description": "高优先级策略",
      "violation_impact": "显著业务影响",
      "review_cycle": "quarterly"
    },
    "medium": {
      "description": "中等优先级策略",
      "violation_impact": "中等业务影响",
      "review_cycle": "quarterly"
    },
    "low": {
      "description": "低优先级策略",
      "violation_impact": "轻微业务影响",
      "review_cycle": "semi-annually"
    },
    "info": {
      "description": "信息性策略",
      "violation_impact": "无直接影响",
      "review_cycle": "annually"
    }
  },
  "rollout_modes": {
    "immediate": {
      "description": "立即生效",
      "applicable_severity": ["critical", "high"]
    },
    "gradual": {
      "description": "渐进生效",
      "stages": ["canary", "early", "beta", "full"]
    },
    "opt-in": {
      "description": "主动启用",
      "applicable_severity": ["low", "info"]
    },
    "opt-out": {
      "description": "默认启用，可退出",
      "applicable_severity": ["medium", "low"]
    }
  }
}
