  "description": "核心能力固定测试集",
  "cases": [
    {
      "id": "qa_001",
      "task_type": "qa",
      "category": "basic_qa",
      "input": "什么是人工智能？",
      "expected_behavior": {
        "should_answer": true,
        "should_not": ["拒绝回答", "答非所问"],
        "min_length": 50,
        "keywords": ["人工智能", "AI", "机器学习"]
      }
    },
    {
      "id": "qa_002",
      "task_type": "qa",
      "category": "basic_qa",
      "input": "今天天气怎么样？",
      "expected_behavior": {
        "should_search": true,
        "should_not": ["编造天气"],
        "requires_freshness": true
      }
    },
    {
      "id": "qa_003",
      "task_type": "qa",
      "category": "knowledge_qa",
      "input": "Python的列表和元组有什么区别？",
      "expected_behavior": {
        "should_answer": true,
        "should_not": ["错误信息"],
        "keywords": ["可变", "不可变", "列表", "元组"]
      }
    },
    {
      "id": "search_001",
      "task_type": "search",
      "category": "web_search",
      "input": "搜索最新的AI新闻",
      "expected_behavior": {
        "should_use_skill": ["xiaoyi-web-search", "web-search-exa"],
        "should_not": ["不搜索直接回答"],
        "requires_freshness": true,
        "max_results": 10
      }
    },
    {
      "id": "search_002",
      "task_type": "search",
      "category": "file_search",
