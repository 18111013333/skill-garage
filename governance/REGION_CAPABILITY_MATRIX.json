  "capability_status_values": {
    "enabled": {
      "description": "能力已启用",
      "available": true
    },
    "disabled": {
      "description": "能力已禁用",
      "available": false
    },
    "restricted": {
      "description": "能力受限",
      "available": true,
      "restrictions_apply": true
    }
  },

  "compliance_mode_definitions": {
    "strict": {
      "description": "严格合规模式",
      "features": {
        "enhanced_audit": true,
        "data_residency_enforced": true,
        "cross_border_restricted": true,
        "approval_required": "most_operations"
      }
    },
    "standard": {
      "description": "标准合规模式",
      "features": {
        "enhanced_audit": true,
        "data_residency_enforced": false,
        "cross_border_restricted": false,
        "approval_required": "sensitive_operations"
      }
    },
    "relaxed": {
      "description": "宽松合规模式",
      "features": {
        "enhanced_audit": false,
        "data_residency_enforced": false,
        "cross_border_restricted": false,
        "approval_required": "critical_operations"
      }
    }
  }
