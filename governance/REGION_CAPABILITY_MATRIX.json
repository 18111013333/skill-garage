{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "REGION_CAPABILITY_MATRIX",
  "description": "区域能力矩阵，定义各区域的能力开放与限制",
  "version": "1.0.0",
  "updated_at": "2026-04-07",

  "matrix_metadata": {
    "total_regions": 8,
    "total_capabilities": 15,
    "last_review_date": "2026-04-07",
    "next_review_date": "2026-07-07"
  },

  "region_schema": {
    "region_id": {
      "type": "string",
      "description": "区域唯一标识符",
      "pattern": "^[A-Z]+-[A-Z]+$"
    },
    "region_name": {
      "type": "string",
      "description": "区域名称"
    },
    "region_type": {
      "type": "string",
      "enum": ["primary", "secondary", "special"],
      "description": "区域类型"
    },
    "compliance_jurisdiction": {
      "type": "string",
      "description": "合规管辖区"
    },
    "allowed_models": {
      "type": "array",
      "items": {"type": "string"},
      "description": "允许使用的模型列表"
    },
    "allowed_integrations": {
      "type": "array",
      "items": {"type": "string"},
      "description": "允许的第三方集成列表"
    },
    "allowed_autonomy_level": {
      "type": "string",
      "enum": ["none", "low", "medium", "high", "full"],
      "description": "允许的自主执行级别"
    },
    "export_limits": {
      "type": "object",
      "properties": {
        "max_export_size_mb": {"type": "number"},
        "max_export_count_per_day": {"type": "number"},
        "requires_approval": {"type": "boolean"},
        "cross_region_allowed": {"type": "boolean"},
        "cross_border_allowed": {"type": "boolean"}
      },
      "description": "导出限制"
    },
    "retention_overrides": {
      "type": "object",
      "properties": {
        "min_retention_days": {"type": "number"},
        "max_retention_days": {"type": "number"},
        "audit_retention_years": {"type": "number"}
      },
      "description": "保留期限覆盖"
    },
    "compliance_mode": {
      "type": "string",
      "enum": ["strict", "standard", "relaxed"],
      "description": "合规模式"
    },
    "tenant_overrides_allowed": {
      "type": "boolean",
      "description": "是否允许租户覆盖"
    },
    "data_residency": {
      "type": "object",
      "properties": {
        "enforced": {"type": "boolean"},
        "cross_region_sync": {"type": "boolean"},
        "cross_border_transfer": {"type": "string", "enum": ["prohibited", "restricted", "allowed"]}
      },
      "description": "数据驻留规则"
    },
    "capabilities": {
      "type": "object",
      "description": "能力开关"
    }
  },

  "capability_definitions": {
    "dialogue": {
      "name": "对话服务",
      "description": "核心对话能力",
      "category": "core",
      "default_status": "enabled"
    },
    "memory": {
      "name": "记忆服务",
      "description": "长期记忆能力",
      "category": "core",
      "default_status": "enabled"
    },
    "tools": {
      "name": "工具服务",
      "description": "工具调用能力",
      "category": "core",
      "default_status": "enabled"
    },
    "export": {
      "name": "导出服务",
      "description": "数据导出能力",
      "category": "data",
      "default_status": "enabled"
    },
    "batch_operations": {
      "name": "批量操作",
      "description": "批量处理能力",
      "category": "data",
      "default_status": "enabled"
    },
    "automation": {
      "name": "自动化任务",
      "description": "自动化执行能力",
      "category": "automation",
      "default_status": "enabled"
    },
    "scheduling": {
      "name": "定时任务",
      "description": "定时执行能力",
      "category": "automation",
      "default_status": "enabled"
    },
    "web_browsing": {
      "name": "网页浏览",
      "description": "网页访问能力",
      "category": "integration",
      "default_status": "enabled"
    },
    "file_operations": {
      "name": "文件操作",
      "description": "文件读写能力",
      "category": "data",
      "default_status": "enabled"
    },
    "code_execution": {
      "name": "代码执行",
      "description": "代码运行能力",
      "category": "advanced",
      "default_status": "restricted"
    },
    "shell_access": {
      "name": "Shell 访问",
      "description": "Shell 命令执行",
      "category": "advanced",
      "default_status": "disabled"
    },
    "external_api": {
      "name": "外部 API",
      "description": "外部 API 调用",
      "category": "integration",
      "default_status": "enabled"
    },
    "reporting": {
      "name": "报表服务",
      "description": "报表生成能力",
      "category": "analytics",
      "default_status": "enabled"
    },
    "analytics": {
      "name": "分析服务",
      "description": "数据分析能力",
      "category": "analytics",
      "default_status": "enabled"
    }
  },

  "autonomy_levels": {
    "none": {
      "description": "无自主执行",
      "allowed_actions": [],
      "requires_approval": "all"
    },
    "low": {
      "description": "低自主执行",
      "allowed_actions": ["read", "query"],
      "requires_approval": ["write", "delete", "export"]
    },
    "medium": {
      "description": "中等自主执行",
      "allowed_actions": ["read", "query", "write"],
      "requires_approval": ["delete", "export", "external"]
    },
    "high": {
      "description": "高自主执行",
      "allowed_actions": ["read", "query", "write", "delete"],
      "requires_approval": ["export", "external", "sensitive"]
    },
    "full": {
      "description": "完全自主执行",
      "allowed_actions": ["all"],
      "requires_approval": ["sensitive"]
    }
  },

