{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SLO Definitions",
  "description": "核心 SLO 结构化定义",
  "type": "object",
  "required": ["slo_id", "service_name", "metric_name", "target_value", "owner"],
  "properties": {
    "slo_id": {
      "type": "string",
      "description": "SLO 唯一标识",
      "pattern": "^slo_[a-z0-9_]+$"
    },
    "service_name": {
      "type": "string",
      "description": "服务名称"
    },
    "metric_name": {
      "type": "string",
      "description": "指标名称",
      "enum": [
        "availability",
        "latency_p50",
        "latency_p95",
        "latency_p99",
        "error_rate",
        "success_rate",
        "throughput",
        "tool_success_rate",
        "major_error_rate",
        "rollback_frequency",
        "data_durability",
        "recovery_time"
      ]
    },
    "metric_description": {
      "type": "string",
      "description": "指标描述"
    },
    "target_value": {
      "type": "number",
      "description": "目标值",
      "minimum": 0
    },
    "target_unit": {
      "type": "string",
      "enum": ["percent", "ms", "seconds", "count", "ratio"],
      "description": "目标值单位"
    },
    "measurement_window": {
      "type": "object",
      "description": "测量窗口",
      "properties": {
        "duration": {"type": "integer"},
        "unit": {"type": "string", "enum": ["minutes", "hours", "days"]}
      }
    },
    "alert_threshold": {
      "type": "number",
      "description": "告警阈值（目标值的百分比）",
      "minimum": 0,
      "maximum": 100
    },
    "owner": {
      "type": "string",
      "description": "SLO 负责人"
    },
    "environment_scope": {
      "type": "array",
      "description": "适用环境",
      "items": {
        "type": "string",
        "enum": ["production", "staging", "sandbox"]
      }
    },
    "exclusion_rules": {
      "type": "array",
      "description": "排除规则",
      "items": {
        "type": "object",
        "properties": {
          "condition": {"type": "string"},
          "reason": {"type": "string"}
        }
      }
    },
    "burn_rate_alerts": {
      "type": "array",
      "description": "燃烧率告警",
      "items": {
        "type": "object",
        "properties": {
          "burn_rate": {"type": "number"},
          "window_hours": {"type": "integer"},
          "severity": {"type": "string", "enum": ["warning", "critical"]}
        }
      }
    },
    "error_budget": {
      "type": "object",
      "description": "错误预算",
      "properties": {
        "budget_period": {"type": "string"},
        "total_budget": {"type": "number"},
        "remaining_budget": {"type": "number"},
        "budget_consumed_percent": {"type": "number"}
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["active", "paused", "deprecated"],
      "default": "active"
    }
  }
}
