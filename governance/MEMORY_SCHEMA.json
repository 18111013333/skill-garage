{
  "version": "1.0.0",
  "lastUpdated": "2026-04-06T12:40:00+08:00",
  "description": "记忆数据结构定义",
  "schemas": {
    "memoryEntry": {
      "id": "memory_entry",
      "description": "记忆条目统一结构",
      "fields": {
        "id": {
          "type": "string",
          "required": true,
          "description": "唯一标识符"
        },
        "fact": {
          "type": "string",
          "required": true,
          "description": "事实内容"
        },
        "source": {
          "type": "string",
          "required": true,
          "enum": ["user_explicit", "user_inferred", "system_inferred", "external_doc", "external_web"],
          "description": "信息来源"
        },
        "confidence": {
          "type": "number",
          "required": true,
          "min": 0,
          "max": 1,
          "description": "置信度"
        },
        "scope": {
          "type": "string",
          "required": true,
          "enum": ["session", "scenario", "permanent"],
          "description": "作用范围"
        },
        "type": {
          "type": "string",
          "required": true,
          "enum": ["user_profile", "system_config", "knowledge", "event", "preference", "constraint"],
          "description": "记忆类型"
        },
        "created_at": {
          "type": "datetime",
          "required": true,
          "description": "创建时间"
        },
        "updated_at": {
          "type": "datetime",
          "required": true,
          "description": "更新时间"
        },
        "expires_at": {
          "type": "datetime",
          "required": false,
          "description": "过期时间"
        },
        "conflict_with": {
          "type": "array",
          "items": { "type": "string" },
          "required": false,
          "description": "冲突的记忆ID列表"
        },
        "status": {
          "type": "string",
          "required": true,
          "enum": ["active", "stale", "archived", "deleted"],
          "description": "状态"
        },
        "access_count": {
          "type": "integer",
          "required": false,
          "default": 0,
          "description": "访问次数"
        },
        "last_accessed": {
          "type": "datetime",
          "required": false,
          "description": "最后访问时间"
        },
        "is_sensitive": {
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "是否敏感"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "required": false,
          "description": "标签"
        }
      }
    },
    "sessionMemory": {
      "id": "session_memory",
      "storage": "session-summaries/*.jsonl",
      "lifecycle": "single_session",
      "fields": {
        "sessionId": {
          "type": "string",
          "required": true,
          "index": true
        },
        "timestamp": {
          "type": "datetime",
          "required": true,
          "index": true
        },
        "role": {
          "type": "string",
          "enum": ["user", "assistant", "system"],
          "required": true
        },
        "content": {
          "type": "text",
          "required": true,
          "maxLength": 10000
        },
        "metadata": {
          "type": "object",
          "required": false,
          "properties": {
            "intent": { "type": "string" },
            "entities": { "type": "array" },
            "sentiment": { "type": "string" }
          }
        }
      }
    },
    "scenarioMemory": {
      "id": "scenario_memory",
      "storage": "scenarios/*.md",
      "lifecycle": "cross_session",
      "fields": {
        "scenarioId": {
          "type": "string",
          "required": true,
          "index": true
        },
        "name": {
          "type": "string",
          "required": true,
          "maxLength": 100
        },
        "type": {
          "type": "string",
          "enum": ["work", "learning", "personal", "project"],
          "required": true
        },
        "data": {
          "type": "object",
          "required": true
        },
        "lastAccessed": {
          "type": "datetime",
          "required": true,
          "index": true
        },
        "accessCount": {
          "type": "integer",
          "default": 0
        }
      }
    },
    "longTermMemory": {
      "id": "long_term_memory",
      "storage": "MEMORY.md + memory/*.md",
      "lifecycle": "permanent",
      "fields": {
        "memoryId": {
          "type": "string",
          "required": true,
          "index": true
        },
        "type": {
          "type": "string",
          "enum": ["user_profile", "system_config", "knowledge", "event", "preference", "constraint"],
          "required": true
        },
        "key": {
          "type": "string",
          "required": true,
          "index": true
        },
        "value": {
          "type": "any",
          "required": true
        },
        "source": {
          "type": "string",
          "enum": ["user_explicit", "user_inferred", "system_inferred", "external_doc", "external_web"],
          "required": true
        },
        "confidence": {
          "type": "number",
          "min": 0,
          "max": 1,
          "default": 1
        },
        "createdAt": {
          "type": "datetime",
          "required": true
        },
        "updatedAt": {
          "type": "datetime",
          "required": true
        },
        "expiresAt": {
          "type": "datetime",
          "required": false
        },
        "isSensitive": {
          "type": "boolean",
          "default": false
        },
        "status": {
          "type": "string",
          "enum": ["active", "stale", "archived", "deleted"],
          "default": "active"
        }
      }
    }
  },
  "indexes": {
    "primary": ["id", "memoryId", "sessionId", "scenarioId"],
    "secondary": ["type", "source", "status", "createdAt", "updatedAt"],
    "vector": {
      "enabled": true,
      "provider": "voyage",
      "model": "voyage-4-large",
      "dimensions": 1024
    }
  },
  "validation": {
    "strictMode": true,
    "onValidationError": "reject",
    "customValidators": []
  },
  "retention": {
    "session": "7 days",
    "scenario": "90 days",
    "permanent": "365 days",
    "archive": "indefinite"
  }
}
