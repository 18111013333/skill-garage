{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Policy Schema",
  "description": "策略代码对象结构 - 终极鸽子王 V27.0",
  "version": "1.0.0",
  "type": "object",
  "required": ["policy_id", "policy_name", "policy_domain", "policy_scope", "policy_version", "enforcement_mode"],
  "properties": {
    "policy_id": {
      "type": "string",
      "description": "策略唯一标识符",
      "pattern": "^pac_[a-zA-Z0-9_]+$"
    },
    "policy_name": {
      "type": "string",
      "description": "策略名称",
      "minLength": 1,
      "maxLength": 128
    },
    "policy_code": {
      "type": "string",
      "description": "策略代码（用于引用）",
      "pattern": "^[a-z_]{3,64}$"
    },
    "policy_description": {
      "type": "string",
      "description": "策略描述",
      "maxLength": 1024
    },
    "policy_domain": {
      "type": "string",
      "enum": [
        "access_control",
        "data_governance",
        "privacy",
        "security",
        "compliance",
        "retention",
        "audit",
        "rate_limit",
        "cost_control",
        "resource_quota",
        "change_management",
        "incident_management",
        "service_level",
        "deployment",
        "evolution"
      ],
      "description": "策略领域"
    },
    "policy_scope": {
      "type": "string",
      "enum": ["global", "tenant", "project", "user", "resource", "region"],
      "description": "策略作用域"
    },
    "policy_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "策略版本"
    },
    "policy_status": {
      "type": "string",
      "enum": ["draft", "testing", "active", "deprecated", "archived"],
      "default": "draft",
      "description": "策略状态"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {
            "type": "string",
            "description": "输入参数名"
          },
          "type": {
            "type": "string",
            "enum": ["string", "number", "boolean", "object", "array", "enum"],
            "description": "参数类型"
          },
          "required": {
            "type": "boolean",
            "default": false,
            "description": "是否必填"
          },
          "default": {
            "description": "默认值"
          },
          "enum_values": {
            "type": "array",
            "items": {},
            "description": "枚举值（type=enum时）"
          },
          "validation": {
            "type": "object",
            "properties": {
              "min": { "type": "number" },
              "max": { "type": "number" },
              "pattern": { "type": "string" },
              "custom_validator": { "type": "string" }
            },
            "description": "验证规则"
          },
          "description": {
            "type": "string",
            "description": "参数说明"
          }
        }
      },
      "description": "策略输入参数"
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {
            "type": "string",
            "description": "输出参数名"
          },
          "type": {
            "type": "string",
            "enum": ["string", "number", "boolean", "object", "array", "decision"],
            "description": "输出类型"
          },
          "description": {
            "type": "string",
            "description": "输出说明"
          }
        }
      },
      "description": "策略输出"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule_id", "condition", "action"],
        "properties": {
          "rule_id": {
            "type": "string",
            "description": "规则ID"
          },
          "rule_name": {
            "type": "string",
            "description": "规则名称"
          },
          "priority": {
            "type": "integer",
            "minimum": 1,
            "default": 100,
            "description": "规则优先级（越小越优先）"
          },
          "condition": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["all", "any", "none", "custom"],
                "description": "条件类型"
              },
              "expressions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "field": { "type": "string" },
                    "operator": {
                      "type": "string",
                      "enum": ["eq", "ne", "gt", "gte", "lt", "lte", "in", "not_in", "contains", "matches", "exists"]
                    },
                    "value": {}
                  }
                },
                "description": "条件表达式"
              },
              "custom_evaluator": {
                "type": "string",
                "description": "自定义评估器（type=custom时）"
              }
            },
            "description": "规则条件"
          },
          "action": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["allow", "deny", "modify", "alert", "log", "custom"],
                "description": "动作类型"
              },
              "params": {
                "type": "object",
                "description": "动作参数"
              },
              "custom_handler": {
                "type": "string",
                "description": "自定义处理器（type=custom时）"
              }
            },
            "description": "规则动作"
          },
          "metadata": {
            "type": "object",
            "description": "规则元数据"
          }
        }
      },
      "description": "策略规则"
    },
    "default_decision": {
      "type": "string",
      "enum": ["allow", "deny"],
      "default": "deny",
      "description": "默认决策（无规则匹配时）"
    },
    "enforcement_mode": {
      "type": "string",
      "enum": ["strict", "moderate", "advisory", "disabled"],
      "description": "执行模式"
    },
    "exception_mode": {
      "type": "object",
      "properties": {
        "allow_exceptions": {
          "type": "boolean",
          "default": true,
          "description": "是否允许例外"
        },
        "exception_approval": {
          "type": "string",
          "enum": ["auto", "manual", "none"],
          "default": "manual",
          "description": "例外审批方式"
        },
        "exception_duration_max": {
          "type": "string",
          "description": "例外最大有效期"
        },
        "exception_audit": {
          "type": "boolean",
          "default": true,
          "description": "例外是否审计"
        }
      },
      "description": "例外模式"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "policy_id": { "type": "string" },
          "dependency_type": {
            "type": "string",
            "enum": ["requires", "conflicts", "extends", "overrides"]
          }
        }
      },
      "description": "策略依赖"
    },
    "owner": {
      "type": "object",
      "properties": {
        "owner_id": { "type": "string" },
        "owner_name": { "type": "string" },
        "team": { "type": "string" },
        "contact": { "type": "string" }
      },
      "description": "策略负责人"
    },
    "testing": {
      "type": "object",
      "properties": {
        "test_coverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "测试覆盖率（%）"
        },
        "test_cases": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "case_id": { "type": "string" },
              "description": { "type": "string" },
              "input": { "type": "object" },
              "expected_output": { "type": "object" }
            }
          },
          "description": "测试用例"
        },
        "last_test_run": {
          "type": "string",
          "format": "date-time",
          "description": "上次测试运行时间"
        },
        "test_result": {
          "type": "string",
          "enum": ["passed", "failed", "pending"],
          "description": "测试结果"
        }
      },
      "description": "测试信息"
    },
    "deployment": {
      "type": "object",
      "properties": {
        "environments": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["development", "staging", "canary", "production"]
          },
          "description": "已部署环境"
        },
        "current_environment": {
          "type": "string",
          "description": "当前生效环境"
        },
        "deployment_history": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "version": { "type": "string" },
              "environment": { "type": "string" },
              "deployed_at": { "type": "string", "format": "date-time" },
              "deployed_by": { "type": "string" }
            }
          },
          "description": "部署历史"
        }
      },
      "description": "部署信息"
    },
    "audit": {
      "type": "object",
      "properties": {
        "execution_count": { "type": "number" },
        "allow_count": { "type": "number" },
        "deny_count": { "type": "number" },
        "exception_count": { "type": "number" },
        "last_execution": { "type": "string", "format": "date-time" }
      },
      "description": "审计统计"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "扩展元数据"
    }
  },
  "enforcement_modes": {
    "strict": {
      "description": "严格模式",
      "behavior": "严格执行，违规即阻断",
      "audit_level": "full"
    },
    "moderate": {
      "description": "中等模式",
      "behavior": "执行但允许临时例外",
      "audit_level": "full"
    },
    "advisory": {
      "description": "建议模式",
      "behavior": "仅记录和建议，不阻断",
      "audit_level": "partial"
    },
    "disabled": {
      "description": "禁用模式",
      "behavior": "策略不执行",
      "audit_level": "none"
    }
  },
  "policy_domains": {
    "access_control": { "description": "访问控制策略" },
    "data_governance": { "description": "数据治理策略" },
    "privacy": { "description": "隐私保护策略" },
    "security": { "description": "安全策略" },
    "compliance": { "description": "合规策略" },
    "retention": { "description": "数据保留策略" },
    "audit": { "description": "审计策略" },
    "rate_limit": { "description": "限流策略" },
    "cost_control": { "description": "成本控制策略" },
    "resource_quota": { "description": "资源配额策略" },
    "change_management": { "description": "变更管理策略" },
    "incident_management": { "description": "事故管理策略" },
    "service_level": { "description": "服务等级策略" },
    "deployment": { "description": "部署策略" },
    "evolution": { "description": "进化策略" }
  }
}
