{
  "version": "1.0.0",
  "lastUpdated": "2026-04-06T22:00:00+08:00",
  "description": "数据保留矩阵 - 定义各类数据的保留、归档和删除规则",

  "matrix": [
    {
      "data_type": "session_data",
      "description": "会话数据",
      "sensitivity_level": "L2",
      "retention_period": {
        "active": "90_days",
        "archived": "180_days",
        "maximum": "365_days"
      },
      "archival_rule": {
        "trigger": "session_end + 30_days",
        "location": "archive/sessions/",
        "format": "compressed_json",
        "encryption": true
      },
      "deletion_rule": {
        "method": "secure_delete",
        "verification": "checksum_validation",
        "cascade": ["session_logs", "session_cache"]
      },
      "tenant_override_allowed": {
        "retention_shorter": true,
        "retention_longer": false,
        "archival_location": true,
        "deletion_method": false
      },
      "legal_hold_supported": true,
      "audit_required": true
    },
    {
      "data_type": "memory_data",
      "description": "记忆数据",
      "sensitivity_level": "L2",
      "retention_period": {
        "active": "permanent",
        "archived": "365_days",
        "maximum": "permanent"
      },
      "archival_rule": {
        "trigger": "last_access + 180_days",
        "location": "archive/memory/",
        "format": "vector_indexed",
        "encryption": true
      },
      "deletion_rule": {
        "method": "cascade_delete",
        "verification": "index_rebuild",
        "cascade": ["memory_index", "memory_vectors"]
      },
      "tenant_override_allowed": {
        "retention_shorter": true,
        "retention_longer": false,
        "archival_location": true,
        "deletion_method": false
      },
      "legal_hold_supported": true,
      "audit_required": true
    },
    {
      "data_type": "audit_logs",
      "description": "审计日志",
      "sensitivity_level": "L1",
      "retention_period": {
        "active": "365_days",
        "archived": "7_years",
        "maximum": "10_years"
      },
      "archival_rule": {
        "trigger": "age > 90_days",
        "location": "archive/audit/",
        "format": "compressed_jsonl",
        "encryption": true
      },
      "deletion_rule": {
        "method": "secure_delete",
        "verification": "checksum_validation",
        "cascade": []
      },
      "tenant_override_allowed": {
        "retention_shorter": false,
        "retention_longer": true,
        "archival_location": true,
        "deletion_method": false
      },
      "legal_hold_supported": true,
      "audit_required": true
    },
    {
      "data_type": "approval_records",
      "description": "审批记录",
      "sensitivity_level": "L1",
      "retention_period": {
        "active": "365_days",
        "archived": "5_years",
        "maximum": "7_years"
      },
      "archival_rule": {
        "trigger": "approval_complete + 90_days",
        "location": "archive/approvals/",
        "format": "compressed_json",
        "encryption": true
      },
      "deletion_rule": {
        "method": "secure_delete",
        "verification": "checksum_validation",
        "cascade": ["approval_attachments"]
      },
      "tenant_override_allowed": {
        "retention_shorter": false,
        "retention_longer": true,
        "archival_location": true,
        "deletion_method": false
      },
      "legal_hold_supported": true,
      "audit_required": true
    },
    {
      "data_type": "knowledge_entries",
      "description": "知识条目",
      "sensitivity_level": "L2",
      "retention_period": {
        "active": "permanent",
        "archived": "365_days",
        "maximum": "permanent"
      },
      "archival_rule": {
        "trigger": "deprecated + 30_days",
        "location": "archive/knowledge/",
        "format": "indexed_json",
        "encryption": true
      },
      "deletion_rule": {
        "method": "soft_delete_then_purge",
        "verification": "index_rebuild",
        "cascade": ["knowledge_index", "knowledge_refs"]
      },
      "tenant_override_allowed": {
        "retention_shorter": true,
        "retention_longer": false,
        "archival_location": true,
        "deletion_method": false
      },
      "legal_hold_supported": true,
      "audit_required": true
    },
    {
      "data_type": "event_logs",
      "description": "事件日志",
      "sensitivity_level": "L1",
      "retention_period": {
        "active": "30_days",
        "archived": "180_days",
        "maximum": "365_days"
      },
      "archival_rule": {
        "trigger": "age > 7_days",
        "location": "archive/events/",
        "format": "compressed_jsonl",
        "encryption": false
      },
      "deletion_rule": {
        "method": "batch_delete",
        "verification": "count_validation",
        "cascade": []
      },
      "tenant_override_allowed": {
        "retention_shorter": true,
        "retention_longer": true,
        "archival_location": true,
        "deletion_method": true
      },
      "legal_hold_supported": true,
      "audit_required": false
    },
    {
      "data_type": "billing_records",
      "description": "计费记录",
      "sensitivity_level": "L2",
      "retention_period": {
        "active": "365_days",
        "archived": "7_years",
        "maximum": "10_years"
      },
      "archival_rule": {
        "trigger": "billing_period_end + 90_days",
        "location": "archive/billing/",
        "format": "compressed_json",
        "encryption": true
      },
      "deletion_rule": {
        "method": "secure_delete",
        "verification": "checksum_validation",
        "cascade": ["billing_details", "billing_invoices"]
      },
      "tenant_override_allowed": {
        "retention_shorter": false,
        "retention_longer": true,
        "archival_location": false,
        "deletion_method": false
      },
      "legal_hold_supported": true,
      "audit_required": true
    },
    {
      "data_type": "export_records",
      "description": "导出记录",
      "sensitivity_level": "L1",
      "retention_period": {
        "active": "90_days",
        "archived": "365_days",
        "maximum": "3_years"
      },
      "archival_rule": {
        "trigger": "export_complete + 30_days",
        "location": "archive/exports/",
        "format": "compressed_json",
        "encryption": true
      },
      "deletion_rule": {
        "method": "secure_delete",
        "verification": "checksum_validation",
        "cascade": ["export_files"]
      },
      "tenant_override_allowed": {
        "retention_shorter": true,
        "retention_longer": true,
        "archival_location": true,
        "deletion_method": true
      },
      "legal_hold_supported": true,
      "audit_required": true
    },
    {
      "data_type": "pii_data",
      "description": "个人身份信息",
      "sensitivity_level": "L3",
      "retention_period": {
        "active": "consent_period",
        "archived": "0_days",
        "maximum": "consent_period"
      },
      "archival_rule": {
        "trigger": "none",
        "location": "not_allowed",
        "format": "N/A",
        "encryption": "N/A"
      },
      "deletion_rule": {
        "method": "secure_delete_with_verification",
        "verification": "multi_pass_verification",
        "cascade": ["all_pii_references"]
      },
      "tenant_override_allowed": {
        "retention_shorter": true,
        "retention_longer": false,
        "archival_location": false,
        "deletion_method": false
      },
      "legal_hold_supported": true,
      "audit_required": true
    },
    {
      "data_type": "model_outputs",
      "description": "模型输出",
      "sensitivity_level": "L2",
      "retention_period": {
        "active": "30_days",
        "archived": "90_days",
        "maximum": "180_days"
      },
      "archival_rule": {
        "trigger": "output_time + 7_days",
        "location": "archive/outputs/",
        "format": "compressed_json",
        "encryption": true
      },
      "deletion_rule": {
        "method": "secure_delete",
        "verification": "checksum_validation",
        "cascade": ["output_cache"]
      },
      "tenant_override_allowed": {
        "retention_shorter": true,
        "retention_longer": false,
        "archival_location": true,
        "deletion_method": true
      },
      "legal_hold_supported": true,
      "audit_required": true
    }
  ],

  "default_rules": {
    "unclassified_data": {
      "sensitivity_level": "L2",
      "retention_period": "90_days",
      "deletion_method": "secure_delete"
    }
  },

  "legal_hold": {
    "description": "法律保留规则",
    "effect": "暂停删除和归档",
    "scope": ["all_data_types"],
    "max_duration": "indefinite",
    "release_authority": "legal_department"
  },

  "retention_enforcement": {
    "check_frequency": "daily",
    "batch_size": 1000,
    "notification_before_delete": 7,
    "dry_run_mode": true
  }
}
