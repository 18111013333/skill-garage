{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Control Library",
  "description": "内部控制目录",
  "type": "object",
  "required": ["control_id", "control_name", "objective", "control_type", "owner"],
  "properties": {
    "control_id": {
      "type": "string",
      "description": "控制项唯一标识",
      "pattern": "^ctrl_[a-z0-9_]+$"
    },
    "control_name": {
      "type": "string",
      "description": "控制项名称",
      "minLength": 1,
      "maxLength": 100
    },
    "description": {
      "type": "string",
      "description": "控制项描述"
    },
    "objective": {
      "type": "string",
      "description": "控制目标"
    },
    "control_type": {
      "type": "string",
      "enum": ["preventive", "detective", "corrective"],
      "description": "控制类型：预防型/检测型/纠正型"
    },
    "control_category": {
      "type": "string",
      "enum": [
        "access_control",
        "data_protection",
        "change_management",
        "segregation_of_duties",
        "monitoring",
        "backup_recovery",
        "incident_response",
        "compliance",
        "audit_trail",
        "encryption",
        "authentication",
        "authorization"
      ],
      "description": "控制类别"
    },
    "frequency": {
      "type": "string",
      "enum": ["continuous", "daily", "weekly", "monthly", "quarterly", "annually", "on_demand"],
      "description": "执行频率"
    },
    "owner": {
      "type": "string",
      "description": "控制负责人"
    },
    "implementer": {
      "type": "string",
      "description": "控制实施者"
    },
    "evidence_required": {
      "type": "array",
      "description": "所需证据",
      "items": {
        "type": "object",
        "properties": {
          "evidence_type": {"type": "string"},
          "retention_period": {"type": "string"},
          "storage_location": {"type": "string"}
        }
      }
    },
    "linked_risks": {
      "type": "array",
      "description": "关联风险",
      "items": {
        "type": "string"
      }
    },
    "linked_modules": {
      "type": "array",
      "description": "关联模块",
      "items": {
        "type": "string"
      }
    },
    "linked_controls": {
      "type": "array",
      "description": "关联控制",
      "items": {
        "type": "string"
      }
    },
    "testing_requirements": {
      "type": "object",
      "description": "测试要求",
      "properties": {
        "test_frequency": {"type": "string"},
        "sample_size": {"type": "integer"},
        "test_procedure": {"type": "string"},
        "pass_criteria": {"type": "string"}
      }
    },
    "automation_status": {
      "type": "string",
      "enum": ["fully_automated", "semi_automated", "manual"],
      "description": "自动化状态"
    },
    "effectiveness_rating": {
      "type": "string",
      "enum": ["effective", "partially_effective", "ineffective", "not_tested"],
      "default": "not_tested"
    },
    "last_test_date": {
      "type": "string",
      "format": "date"
    },
    "next_test_date": {
      "type": "string",
      "format": "date"
    },
    "exceptions": {
      "type": "array",
      "description": "例外记录",
      "items": {
        "type": "object",
        "properties": {
          "exception_id": {"type": "string"},
          "reason": {"type": "string"},
          "compensating_control": {"type": "string"},
          "expiry_date": {"type": "string", "format": "date"}
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["active", "inactive", "under_review", "deprecated"],
      "default": "active"
    }
  }
}
